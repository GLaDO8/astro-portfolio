---
interface Props {
    currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const links = [
    { href: "/", label: "Home" },
    { href: "/snaps", label: "Snaps" },
    { href: "/notes", label: "Notes" },
];

const activeLinkClass = "text-charcoal";
const inactiveLinkClass = "text-slate hover:text-charcoal";
---

<nav class="flex items-center justify-end font-sans text-sm tracking-tight">
    <div
        class="relative flex items-center rounded-full bg-[#EAEBE8] p-1"
        data-navbar-track
    >
        <span
            aria-hidden="true"
            class="pointer-events-none absolute inset-y-1 left-0 rounded-full bg-parchment shadow-[0_1px_2px_rgba(36,42,45,0.08),0_8px_18px_rgba(36,42,45,0.06)] transition-[transform,width,opacity] duration-300 ease-[cubic-bezier(0.22,1,0.36,1)]"
            data-navbar-indicator></span>
        {
            links.map(({ href, label }) => {
                const isActive =
                    href === "/"
                        ? currentPath === href
                        : currentPath === href ||
                          currentPath.startsWith(`${href}/`);
                return (
                    <a
                        href={href}
                        class:list={[
                            "relative z-10 rounded-full px-5 pt-1 pb-1.5 font-semibold transition-[color,transform] duration-200",
                            isActive ? activeLinkClass : inactiveLinkClass,
                        ]}
                        aria-current={isActive ? "page" : undefined}
                        data-navbar-link
                    >
                        {label}
                    </a>
                );
            })
        }
    </div>
</nav>

<script>
    const track = document.querySelector<HTMLElement>("[data-navbar-track]");
    const indicator = track?.querySelector<HTMLElement>(
        "[data-navbar-indicator]",
    );
    const links = track
        ? Array.from(track.querySelectorAll<HTMLElement>("[data-navbar-link]"))
        : [];

    if (track && indicator && links.length > 0) {
        let activeLink =
            links.find(
                (link) => link.getAttribute("aria-current") === "page",
            ) ?? links[0];

        const activeClass = "text-charcoal";
        const inactiveClass = "text-slate";
        const inactiveHoverClass = "hover:text-charcoal";

        const moveIndicator = (link: HTMLElement) => {
            const trackRect = track.getBoundingClientRect();
            const linkRect = link.getBoundingClientRect();
            indicator.style.width = `${linkRect.width}px`;
            indicator.style.transform = `translateX(${linkRect.left - trackRect.left}px)`;
            indicator.style.opacity = "1";
        };

        const setActiveLink = (link: HTMLElement) => {
            activeLink = link;
            for (const currentLink of links) {
                const isCurrent = currentLink === link;
                currentLink.toggleAttribute("aria-current", isCurrent);
                currentLink.classList.toggle(activeClass, isCurrent);
                currentLink.classList.toggle(inactiveClass, !isCurrent);
                currentLink.classList.toggle(inactiveHoverClass, !isCurrent);
            }
            moveIndicator(link);
        };

        indicator.style.transition = "none";
        setActiveLink(activeLink);

        requestAnimationFrame(() => {
            indicator.style.removeProperty("transition");
        });

        window.addEventListener("resize", () => moveIndicator(activeLink));

        for (const link of links) {
            link.addEventListener("click", () => setActiveLink(link));
        }
    }
</script>
