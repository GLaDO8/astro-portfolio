---
import { isNavbarLinkActive } from "@/lib/navbar-active-path.js";

interface Props {
	currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const links = [
	{ href: "/work", label: "work" },
	{ href: "/sidequests", label: "sidequests" },
	{ href: "/notes", label: "notes" },
];

const activeLinkClass = "text-charcoal";
const inactiveLinkClass = "text-charcoal/70 hover:text-charcoal";
---

<nav
    class="mx-auto flex w-full max-w-[39.25rem] items-center justify-between px-4 font-sans text-sm tracking-[-0.01em] md:px-0 md:text-base"
    aria-label="Primary navigation"
    data-navbar
>
    <a
        href="/"
        class="group flex items-center gap-1.5 font-semibold text-charcoal no-underline transition-colors hover:text-charcoal/80"
        aria-label="shrey.fyi home"
    >
        <span>shrey.fyi</span>
        <span
            aria-hidden="true"
            class="flex size-4 items-center justify-center rounded-full bg-mist text-charcoal/55 transition-colors group-hover:text-charcoal"
        >
            <svg
                aria-hidden="true"
                class="size-2.5"
                viewBox="0 0 16 16"
                fill="none"
                focusable="false"
            >
                <path
                    d="M4 6.25L8 10.25L12 6.25"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
            </svg>
        </span>
    </a>

    <div class="flex items-center gap-4 font-medium md:gap-6">
        {
            links.map(({ href, label }) => {
                const isActive = isNavbarLinkActive(href, currentPath);
                return (
                    <a
                        href={href}
                        class:list={[
                            "rounded-full py-1 transition-colors duration-200",
                            isActive ? activeLinkClass : inactiveLinkClass,
                        ]}
                        aria-current={isActive ? "page" : undefined}
                        data-navbar-link
                    >
                        {label}
                    </a>
                );
            })
        }
    </div>
</nav>

<script>
    import { isNavbarLinkActive } from "@/lib/navbar-active-path.js";

    const activeClass = "text-charcoal";
    const inactiveClass = "text-charcoal/70";
    const inactiveHoverClass = "hover:text-charcoal";

    const getNavbar = () =>
        document.querySelector<HTMLElement>("[data-navbar]");

    const setActiveLink = (
        links: HTMLElement[],
        link: HTMLElement,
    ) => {
        for (const currentLink of links) {
            const isCurrent = currentLink === link;
            currentLink.toggleAttribute("aria-current", isCurrent);
            currentLink.classList.toggle(activeClass, isCurrent);
            currentLink.classList.toggle(inactiveClass, !isCurrent);
            currentLink.classList.toggle(inactiveHoverClass, !isCurrent);
        }
    };

    const syncNavbar = (pathname = window.location.pathname) => {
        const navbar = getNavbar();
        const links = navbar
            ? Array.from(
                  navbar.querySelectorAll<HTMLElement>("[data-navbar-link]"),
              )
            : [];

        if (!navbar || links.length === 0) {
            return;
        }

        const activeLink = links.find((link) =>
            isNavbarLinkActive(link.getAttribute("href") ?? "", pathname),
        );

        for (const link of links) {
            const isCurrent = link === activeLink;
            link.toggleAttribute("aria-current", isCurrent);
            link.classList.toggle(activeClass, isCurrent);
            link.classList.toggle(inactiveClass, !isCurrent);
            link.classList.toggle(inactiveHoverClass, !isCurrent);
        }
    };

    const bindNavbar = () => {
        const navbar = getNavbar();

        if (!navbar || navbar.dataset.navbarBound === "true") {
            return;
        }

        const links = Array.from(
            navbar.querySelectorAll<HTMLElement>("[data-navbar-link]"),
        );

        if (links.length === 0) {
            return;
        }

        navbar.dataset.navbarBound = "true";

        for (const link of links) {
            link.addEventListener("click", (event) => {
                if (
                    event.defaultPrevented ||
                    event.button !== 0 ||
                    event.metaKey ||
                    event.ctrlKey ||
                    event.shiftKey ||
                    event.altKey
                ) {
                    return;
                }

                const href = link.getAttribute("href");

                if (!href || href.startsWith("#") || link.target === "_blank") {
                    return;
                }

                const nextUrl = new URL(href, window.location.href);

                if (nextUrl.origin !== window.location.origin) {
                    return;
                }

                setActiveLink(links, link);
            });
        }
    };

    const initNavbar = () => {
        bindNavbar();
        syncNavbar();
    };

    document.addEventListener("astro:page-load", initNavbar);
    initNavbar();
</script>
