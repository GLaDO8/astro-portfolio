---
import { cn } from "@/lib/cn";
import { isNavbarLinkActive } from "@/lib/navbar-active-path.js";

interface Props {
	currentPath?: string;
	class?: string;
	blurBackground?: string;
}

const {
	currentPath = Astro.url.pathname,
	class: className,
	blurBackground = "var(--color-beige)",
} = Astro.props;
const shellClass = cn("sticky top-4 z-40 mx-auto mb-12 w-full max-w-[39.25rem]", className);
const blurBackgroundStyle = `--navbar-blur-background: ${blurBackground}`;

const links = [
	{ href: "/noon", label: "From Noon? click here" },
	{ href: "/sidequests", label: "side quests" },
	{ href: "/notes", label: "notes" },
];

const subdomainLinks = [
	{
		href: "https://co2.shrey.fyi",
		label: "co2.shrey.fyi",
		description: "A visual reference for carbon dioxide and climate.",
		iconHref: "https://co2.shrey.fyi/favicon.ico",
	},
];

const activeLinkClass = "text-primary font-semibold";
const inactiveLinkClass = "text-primary/70 hover:text-primary";
---

<!-- progressive blur -->
<div class="navbar-blur" style={blurBackgroundStyle} aria-hidden="true">
    <div class="navbar-blur__background"></div>
    <div class="navbar-blur__filter navbar-blur__filter--soft"></div>
    <div class="navbar-blur__filter navbar-blur__filter--medium"></div>
    <div class="navbar-blur__filter navbar-blur__filter--strong"></div>
    <div class="navbar-blur__filter navbar-blur__filter--extra"></div>
</div>

<div class={shellClass} data-navbar-shell>
    <div transition:persist transition:name="site-navbar">
        <nav
            class="mx-auto flex w-full max-w-[39.25rem] items-center justify-between px-4 font-sans text-sm tracking-[-0.01em] md:px-0 md:text-lg pt-4"
            aria-label="Primary navigation"
            data-navbar
        >
            <div class="relative flex items-center gap-2" data-navbar-menu-root>
                <a
                    href="/"
                    class="font-semibold text-primary no-underline"
                    aria-label="shrey.fyi home"
                >
                    <span class="pb-0.5 text-lg">shrey.fyi</span>
                </a>
                <button
                    type="button"
                    class="group flex size-5 items-center justify-center rounded-full bg-tertiary/45 text-primary/55 transition-all hover:scale-120 hover:text-primary focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-primary/45"
                    aria-label="Open subdomain menu"
                    aria-controls="subdomain-menu"
                    aria-expanded="false"
                    data-navbar-menu-button
                >
                    <svg
                        aria-hidden="true"
                        class="size-4 transition-transform duration-200"
                        viewBox="0 0 16 16"
                        fill="none"
                        focusable="false"
                        data-navbar-menu-icon
                    >
                        <path
                            d="M4 6.25L8 10.25L12 6.25"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"></path>
                    </svg>
                </button>

                <div
                    id="subdomain-menu"
                    class="absolute top-full left-0 z-50 mt-3 w-72 max-w-[calc(100vw-2rem)] rounded-lg border border-tertiary/40 bg-white p-1.5 shadow-[0_18px_50px_rgba(42,35,29,0.14)] backdrop-blur-md"
                    hidden
                    data-navbar-menu
                >
                    <ul class="grid gap-1" role="list">
                        {
                            subdomainLinks.map(
                                ({ href, label, description, iconHref }) => (
                                    <li>
                                        <a
                                            href={href}
                                            class="flex items-start gap-3 rounded-md px-2.5 py-2 text-primary no-underline transition-colors duration-200 hover:bg-tertiary/35 focus-visible:bg-tertiary/35 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary/35"
                                            data-navbar-menu-item
                                        >
                                            <span
                                                class="flex size-8 shrink-0 items-center justify-center rounded-md bg-white/70"
                                                aria-hidden="true"
                                            >
                                                <img
                                                    src={iconHref}
                                                    alt=""
                                                    class="size-5 rounded-sm"
                                                    loading="lazy"
                                                    decoding="async"
                                                />
                                            </span>
                                            <span class="min-w-0 pt-0.5">
                                                <span class="block text-sm leading-tight font-semibold">
                                                    {label}
                                                </span>
                                                <span class="mt-1 block text-xs leading-snug text-secondary">
                                                    {description}
                                                </span>
                                            </span>
                                        </a>
                                    </li>
                                ),
                            )
                        }
                    </ul>
                </div>
            </div>

            <div class="flex items-center gap-4 font-medium md:gap-6">
                {
                    links.map(({ href, label }) => {
                        const isActive = isNavbarLinkActive(href, currentPath);
                        return (
                            <a
                                href={href}
                                class:list={[
                                    "rounded-full py-1 transition-colors duration-200",
                                    isActive ? activeLinkClass : inactiveLinkClass,
                                ]}
                                aria-current={isActive ? "page" : undefined}
                                data-navbar-link
                            >
                                {label}
                            </a>
                        );
                    })
                }
            </div>
        </nav>
    </div>
</div>

<script>
    import { isNavbarLinkActive } from "@/lib/navbar-active-path.js";

    const activeClasses = ["text-primary", "font-semibold"];
    const inactiveClasses = ["text-primary/70", "hover:text-primary"];

    const getNavbar = () => document.querySelector<HTMLElement>("[data-navbar]");

    const getNavbarMenuElements = (navbar: HTMLElement) => ({
        button: navbar.querySelector<HTMLButtonElement>("[data-navbar-menu-button]"),
        menu: navbar.querySelector<HTMLElement>("[data-navbar-menu]"),
        icon: navbar.querySelector<HTMLElement>("[data-navbar-menu-icon]"),
    });

    const setSubdomainMenuOpen = (navbar: HTMLElement, isOpen: boolean) => {
        const { button, menu, icon } = getNavbarMenuElements(navbar);

        if (!button || !menu) {
            return;
        }

        button.setAttribute("aria-expanded", String(isOpen));
        menu.hidden = !isOpen;
        icon?.classList.toggle("rotate-180", isOpen);
    };

    const setLinkActiveState = (link: HTMLElement, isCurrent: boolean) => {
        if (isCurrent) {
            link.setAttribute("aria-current", "page");
        } else {
            link.removeAttribute("aria-current");
        }

        for (const className of activeClasses) {
            link.classList.toggle(className, isCurrent);
        }

        for (const className of inactiveClasses) {
            link.classList.toggle(className, !isCurrent);
        }
    };

    const setActiveLink = (links: HTMLElement[], activeLink?: HTMLElement) => {
        for (const currentLink of links) {
            setLinkActiveState(currentLink, currentLink === activeLink);
        }
    };

    const bindNavbarDocumentListeners = () => {
        const root = document.documentElement;

        if (root.dataset.navbarDocumentBound === "true") {
            return;
        }

        root.dataset.navbarDocumentBound = "true";

        document.addEventListener("click", (event) => {
            const navbar = getNavbar();

            if (!navbar || navbar.contains(event.target as Node)) {
                return;
            }

            setSubdomainMenuOpen(navbar, false);
        });

        document.addEventListener("keydown", (event) => {
            if (event.key !== "Escape") {
                return;
            }

            const navbar = getNavbar();

            if (!navbar) {
                return;
            }

            const { button } = getNavbarMenuElements(navbar);

            if (button?.getAttribute("aria-expanded") !== "true") {
                return;
            }

            setSubdomainMenuOpen(navbar, false);
            button.focus();
        });
    };

    const syncNavbar = (pathname = window.location.pathname) => {
        const navbar = getNavbar();
        const links = navbar
            ? Array.from(navbar.querySelectorAll<HTMLElement>("[data-navbar-link]"))
            : [];

        if (!navbar || links.length === 0) {
            return;
        }

        const activeLink = links.find((link) =>
            isNavbarLinkActive(link.getAttribute("href") ?? "", pathname),
        );

        setActiveLink(links, activeLink);
    };

    const bindNavbar = () => {
        const navbar = getNavbar();

        if (!navbar || navbar.dataset.navbarBound === "true") {
            return;
        }

        const links = Array.from(
            navbar.querySelectorAll<HTMLElement>("[data-navbar-link]"),
        );

        if (links.length === 0) {
            return;
        }

        navbar.dataset.navbarBound = "true";

        bindNavbarDocumentListeners();

        const { button, menu } = getNavbarMenuElements(navbar);

        button?.addEventListener("click", (event) => {
            event.stopPropagation();

            const isOpen = button.getAttribute("aria-expanded") === "true";
            setSubdomainMenuOpen(navbar, !isOpen);
        });

        menu?.addEventListener("click", (event) => {
            if ((event.target as Element).closest("a")) {
                setSubdomainMenuOpen(navbar, false);
            }
        });

        for (const link of links) {
            link.addEventListener("click", (event) => {
                if (
                    event.defaultPrevented ||
                    event.button !== 0 ||
                    event.metaKey ||
                    event.ctrlKey ||
                    event.shiftKey ||
                    event.altKey
                ) {
                    return;
                }

                const href = link.getAttribute("href");

                if (!href || href.startsWith("#") || link.target === "_blank") {
                    return;
                }

                const nextUrl = new URL(href, window.location.href);

                if (nextUrl.origin !== window.location.origin) {
                    return;
                }

                setActiveLink(links, link);
                setSubdomainMenuOpen(navbar, false);
            });
        }
    };

    const initNavbar = () => {
        bindNavbar();
        syncNavbar();
    };

    document.addEventListener("astro:page-load", initNavbar);
    initNavbar();
</script>

<style>
    .navbar-blur {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        width: 100%;
        height: 140px;
        pointer-events: none;
        z-index: 30;
        --navbar-blur-background: var(--color-beige);
    }

    .navbar-blur__background,
    .navbar-blur__filter {
        position: absolute;
        inset: 0;
    }

    .navbar-blur__background {
        background: var(--navbar-blur-background);
        opacity: 0.8;
        -webkit-mask-image: linear-gradient(
            to bottom,
            black 0%,
            black 45%,
            transparent 85%
        );
        mask-image: linear-gradient(to bottom, black 0%, black 45%, transparent 75%);
    }

    .navbar-blur__filter--soft {
        -webkit-backdrop-filter: blur(2px);
        backdrop-filter: blur(2px);
        -webkit-mask-image: linear-gradient(
            to bottom,
            black 0%,
            black 70%,
            transparent 100%
        );
        mask-image: linear-gradient(to bottom, black 0%, black 70%, transparent 100%);
    }

    .navbar-blur__filter--medium {
        -webkit-backdrop-filter: blur(6px);
        backdrop-filter: blur(6px);
        -webkit-mask-image: linear-gradient(
            to bottom,
            black 0%,
            black 45%,
            transparent 80%
        );
        mask-image: linear-gradient(to bottom, black 0%, black 45%, transparent 80%);
    }

    .navbar-blur__filter--strong {
        -webkit-backdrop-filter: blur(12px);
        backdrop-filter: blur(12px);
        -webkit-mask-image: linear-gradient(
            to bottom,
            black 0%,
            black 25%,
            transparent 55%
        );
        mask-image: linear-gradient(to bottom, black 0%, black 25%, transparent 55%);
    }
    .navbar-blur__filter--extra {
        -webkit-backdrop-filter: blur(16px);
        backdrop-filter: blur(12px);
        -webkit-mask-image: linear-gradient(
            to bottom,
            black 0%,
            black 15%,
            transparent 45%
        );
        mask-image: linear-gradient(to bottom, black 0%, black 25%, transparent 55%);
    }
</style>
