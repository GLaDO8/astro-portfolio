---
interface Props {
	currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const links = [
	{ href: "/", label: "Home" },
	{ href: "/snaps", label: "Snaps" },
	{ href: "/notes", label: "Notes" },
];

const activeLinkClass = "text-charcoal";
const inactiveLinkClass = "text-slate hover:text-charcoal";
---

<nav class="flex items-center justify-end font-sans text-sm tracking-tight">
    <div
        class="relative flex items-center rounded-full bg-[#EAEBE8] p-1"
        data-navbar-track
    >
        <span
            aria-hidden="true"
            class="pointer-events-none absolute inset-y-1 left-0 rounded-full bg-parchment shadow-[0_1px_2px_rgba(36,42,45,0.08),0_8px_18px_rgba(36,42,45,0.06)] transition-[transform,width,opacity] duration-300 ease-[cubic-bezier(0.22,1,0.36,1)]"
            data-navbar-indicator></span>
        {
            links.map(({ href, label }) => {
                const isActive =
                    href === "/"
                        ? currentPath === href
                        : currentPath === href ||
                          currentPath.startsWith(`${href}/`);
                return (
                    <a
                        href={href}
                        class:list={[
                            "relative z-10 rounded-full px-5 pt-1 pb-1.5 font-semibold transition-[color,transform] duration-200",
                            isActive ? activeLinkClass : inactiveLinkClass,
                        ]}
                        aria-current={isActive ? "page" : undefined}
                        data-navbar-link
                    >
                        {label}
                    </a>
                );
            })
        }
    </div>
</nav>

<script>
    const activeClass = "text-charcoal";
    const inactiveClass = "text-slate";
    const inactiveHoverClass = "hover:text-charcoal";

    const getTrack = () =>
        document.querySelector<HTMLElement>("[data-navbar-track]");

    const isLinkActive = (href: string, pathname: string) =>
        href === "/" ? pathname === href : pathname === href || pathname.startsWith(`${href}/`);

    const setActiveLink = (
        track: HTMLElement,
        indicator: HTMLElement,
        links: HTMLElement[],
        link: HTMLElement,
        options?: { immediate?: boolean },
    ) => {
        for (const currentLink of links) {
            const isCurrent = currentLink === link;
            currentLink.toggleAttribute("aria-current", isCurrent);
            currentLink.classList.toggle(activeClass, isCurrent);
            currentLink.classList.toggle(inactiveClass, !isCurrent);
            currentLink.classList.toggle(inactiveHoverClass, !isCurrent);
        }

        if (options?.immediate) {
            indicator.style.transition = "none";
        }

        const trackRect = track.getBoundingClientRect();
        const linkRect = link.getBoundingClientRect();
        indicator.style.width = `${linkRect.width}px`;
        indicator.style.transform = `translateX(${linkRect.left - trackRect.left}px)`;
        indicator.style.opacity = "1";

        if (options?.immediate) {
            requestAnimationFrame(() => {
                indicator.style.removeProperty("transition");
            });
        }
    };

    const syncNavbar = (pathname = window.location.pathname) => {
        const track = getTrack();
        const indicator = track?.querySelector<HTMLElement>(
            "[data-navbar-indicator]",
        );
        const links = track
            ? Array.from(track.querySelectorAll<HTMLElement>("[data-navbar-link]"))
            : [];

        if (!track || !indicator || links.length === 0) {
            return;
        }

        const activeLink =
            links.find((link) =>
                isLinkActive(link.getAttribute("href") ?? "", pathname),
            ) ?? links[0];

        setActiveLink(track, indicator, links, activeLink, {
            immediate: !track.dataset.navbarReady,
        });
        track.dataset.navbarReady = "true";
    };

    const bindNavbar = () => {
        const track = getTrack();

        if (!track || track.dataset.navbarBound === "true") {
            return;
        }

        const indicator = track.querySelector<HTMLElement>("[data-navbar-indicator]");
        const links = Array.from(
            track.querySelectorAll<HTMLElement>("[data-navbar-link]"),
        );

        if (!indicator || links.length === 0) {
            return;
        }

        track.dataset.navbarBound = "true";

        window.addEventListener("resize", () => syncNavbar());

        for (const link of links) {
            link.addEventListener("click", (event) => {
                if (
                    event.defaultPrevented ||
                    event.button !== 0 ||
                    event.metaKey ||
                    event.ctrlKey ||
                    event.shiftKey ||
                    event.altKey
                ) {
                    return;
                }

                const href = link.getAttribute("href");

                if (!href || href.startsWith("#") || link.target === "_blank") {
                    return;
                }

                const nextUrl = new URL(href, window.location.href);

                if (nextUrl.origin !== window.location.origin) {
                    return;
                }

                setActiveLink(track, indicator, links, link);
            });
        }
    };

    const initNavbar = () => {
        bindNavbar();
        syncNavbar();
    };

    document.addEventListener("astro:page-load", initNavbar);
    initNavbar();
</script>
