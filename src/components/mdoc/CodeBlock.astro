---
import { Code } from "astro:components";

interface Props {
	content: string;
	language?: string;
	maxHeight?: string;
}

const { content, language, maxHeight } = Astro.props;
const trimmed = content.replace(/\n$/, "");
---

<div
    class="codeblock not-prose bg-zinc-50 border border-primary/10 rounded-lg overflow-hidden font-mono text-base leading-relaxed font-medium"
    style={maxHeight ? `--codeblock-max-height: ${maxHeight}` : undefined}
    data-lenis-prevent={maxHeight ? "" : undefined}
>
    <Code code={trimmed} lang={language || "text"} theme="github-light" />
</div>

<style>
    .codeblock {
        font-style: normal;
        font-variation-settings:
            "MONO" 1,
            "CASL" 0,
            "slnt" 0,
            "CRSV" 0;
    }

    .codeblock :global(pre) {
        /* biome-ignore lint/complexity/noImportantStyles: Override generated code block backgrounds. */
        background: transparent !important;
        /* biome-ignore lint/complexity/noImportantStyles: Override generated code block backgrounds. */
        background-color: transparent !important;
        max-height: var(--codeblock-max-height, none);
        overflow: auto;
        margin: 0;
        padding: 1.5rem 1rem;
        font-family: inherit;
        font-variation-settings: inherit;
        font-size: var(--text-sm);
        line-height: inherit;
    }

    .codeblock :global(code) {
        font-family: inherit;
        font-variation-settings: inherit;
        font-size: var(--text-sm);
        line-height: inherit;
    }
</style>
