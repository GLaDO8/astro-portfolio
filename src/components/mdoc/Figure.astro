---
import { Image } from "astro:assets";
import { cn } from "@/lib/cn";
import { getImageAsset } from "@/lib/imageAssets";
import { getImageEdgeTone } from "@/lib/imageEdgeTone";

interface Props {
	src: string;
	alt?: string;
	caption?: string;
	width?: "default" | "wide" | "full";
	align?: "center" | "left" | "right";
	maxWidth?: string;
}

const { src, alt = "", caption, width = "default", align = "center", maxWidth } = Astro.props;
const image = getImageAsset(src);
const style = maxWidth ? `max-width: ${maxWidth}` : undefined;
const imageEdgeTone = image ? await getImageEdgeTone(src) : undefined;
const imageEdgeShadowClass =
	imageEdgeTone === "dark"
		? "after:shadow-[inset_0_0_0_1.5px_rgb(255_255_255_/_0.08)]"
		: "after:shadow-[inset_0_0_0_1.5px_rgb(0_0_0_/_0.05)]";

const wrapperClass = cn(
	"not-prose my-24 w-full",
	width !== "default" && `figure-${width}`,
	align === "center" && "flex flex-col items-center",
	align === "left" && "flex flex-col items-start",
	align === "right" && "flex flex-col items-end",
);
---

<figure class={wrapperClass} style={style}>
    {
        image ? (
            <span
                class={cn(
                    "relative block overflow-hidden rounded-xl after:pointer-events-none after:absolute after:inset-0 after:rounded-xl",
                    imageEdgeShadowClass,
                )}
            >
                <Image src={image} alt={alt} loading="lazy" class="w-full rounded-xl" />
            </span>
        ) : (
            <img
                src={src}
                alt={alt}
                loading="lazy"
                decoding="async"
                class="w-full rounded-lg"
            />
        )
    }
    {
        caption && (
            <figcaption class="font-sans text-sm text-slate mt-2">{caption}</figcaption>
        )
    }
</figure>
