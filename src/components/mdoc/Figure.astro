---
import { Image } from "astro:assets";
import { cn } from "@/lib/cn";
import { getImageAsset } from "@/lib/imageAssets";
import { getImageEdgeTone } from "@/lib/imageEdgeTone";

interface Props {
	src: string;
	alt?: string;
	caption?: string;
	width?: "default" | "wide" | "full";
	align?: "center" | "left" | "right";
	maxWidth?: string;
	noStroke?: boolean;
}

const {
	src,
	alt = "",
	caption,
	width = "default",
	align = "center",
	maxWidth,
	noStroke = false,
} = Astro.props;
const image = getImageAsset(src);
const maxWidthClasses: Record<string, string> = {
	"24rem": "max-w-96",
	"28rem": "max-w-md",
	"32rem": "max-w-lg",
	"36rem": "max-w-xl",
	"42rem": "max-w-2xl",
	"48rem": "max-w-3xl",
	"56rem": "max-w-4xl",
	"64rem": "max-w-5xl",
	"72rem": "max-w-6xl",
	"80rem": "max-w-7xl",
};
const maxWidthClass = maxWidth ? maxWidthClasses[maxWidth] : undefined;

if (maxWidth && !maxWidthClass) {
	throw new Error(`Unsupported Figure maxWidth "${maxWidth}". Add a Tailwind class mapping.`);
}

const imageEdgeTone = image ? await getImageEdgeTone(src) : undefined;
const imageEdgeShadowClass =
	imageEdgeTone === "dark" ? "figure-media-edge-dark" : "figure-media-edge-light";
const imageClass = cn("w-full", !noStroke && "rounded-xl");

const wrapperClass = cn(
	"not-prose my-16 w-full",
	width !== "default" && `figure-${width}`,
	align === "center" && "flex flex-col items-center",
	align === "left" && "flex flex-col items-start",
	align === "right" && "flex flex-col items-end",
	maxWidthClass,
);
---

<figure class={wrapperClass}>
    {
        image ? (
            <span
                class={cn(
                    "figure-media",
                    !noStroke && "figure-media-rounded",
                    !noStroke && "figure-media-stroked",
                    !noStroke && imageEdgeShadowClass,
                )}
            >
                <Image src={image} alt={alt} loading="lazy" class={imageClass} />
            </span>
        ) : (
            <img
                src={src}
                alt={alt}
                loading="lazy"
                decoding="async"
                class="w-full rounded-lg"
            />
        )
    }
    {
        caption && (
            <figcaption class="font-sans text-base text-secondary mt-6">
                {caption}
            </figcaption>
        )
    }
</figure>

<style>
    .figure-media {
        position: relative;
        display: block;
        overflow: hidden;
    }

    .figure-media-rounded {
        border-radius: var(--radius-xl);
    }

    .figure-media-stroked::after {
        position: absolute;
        inset: 0;
        border-radius: inherit;
        pointer-events: none;
        content: "";
        box-shadow: inset 0 0 0 1.5px rgb(0 0 0 / 0.05);
    }

    .figure-media-edge-dark::after {
        box-shadow: inset 0 0 0 1.5px rgb(255 255 255 / 0.08);
    }
</style>
