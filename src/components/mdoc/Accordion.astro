---
interface Props {
	title: string;
	subtitle?: string;
}

const { title, subtitle = "Click to read more about this" } = Astro.props;
---

<details class="group not-prose border border-charcoal/10 rounded-lg bg-white overflow-hidden my-8">
	<summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
		<div class="flex flex-col gap-2.5">
			<p class="font-serif font-bold text-base text-[#da0288]">{title}</p>
			<p class="font-sans text-sm text-[#70787e]">
				<span class="group-open:hidden">{subtitle}</span>
				<span class="hidden group-open:inline">Click again to collapse this section</span>
			</p>
		</div>
		<div class="size-8 rounded-full bg-[#fbe5f3] flex items-center justify-center shrink-0">
			<svg class="size-5 text-[#da0288] group-open:hidden" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
				<line x1="10" y1="4" x2="10" y2="16" />
				<line x1="4" y1="10" x2="16" y2="10" />
			</svg>
			<svg class="size-5 text-[#da0288] hidden group-open:block" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
				<line x1="4" y1="10" x2="16" y2="10" />
			</svg>
		</div>
	</summary>
	<div class="px-6 pt-4 pb-9 font-sans font-medium text-base text-[#333f46] leading-relaxed space-y-4">
		<slot />
	</div>
</details>
