---
import { Image } from "astro:assets";
import { cn } from "@/lib/cn";
import { getImageAsset } from "@/lib/imageAssets";

interface Props {
	images: string; // Delimited string: "src|alt,,src|alt"
	speed?: "slow" | "default" | "fast";
	direction?: "left" | "right";
	gap?: string;
	height?: "sm" | "md" | "lg" | "xl";
}

const {
	images: imagesStr,
	speed = "default",
	direction = "left",
	gap = "1rem",
	height = "lg",
} = Astro.props;

const heights: Record<string, string> = {
	sm: "h-32 md:h-40 lg:h-48",
	md: "h-40 md:h-56 lg:h-64",
	lg: "h-48 md:h-64 lg:h-80",
	xl: "h-90 md:h-100 lg:h-160",
};

const items = imagesStr.split(",,").map((entry) => {
	const [src, alt] = entry.split("|");
	const path = src.trim();
	return { src: path, alt: alt?.trim() || "", image: getImageAsset(path) };
});

const durations: Record<string, string> = {
	slow: "60s",
	default: "35s",
	fast: "20s",
};
const gapClasses: Record<string, string> = {
	"1rem": "gap-4",
};
const animationClasses: Record<string, Record<string, string>> = {
	slow: {
		left: "animate-[marquee-scroll_60s_linear_infinite_normal]",
		right: "animate-[marquee-scroll_60s_linear_infinite_reverse]",
	},
	default: {
		left: "animate-[marquee-scroll_35s_linear_infinite_normal]",
		right: "animate-[marquee-scroll_35s_linear_infinite_reverse]",
	},
	fast: {
		left: "animate-[marquee-scroll_20s_linear_infinite_normal]",
		right: "animate-[marquee-scroll_20s_linear_infinite_reverse]",
	},
};
const gapClass = gapClasses[gap];
const animationClass = animationClasses[speed]?.[direction];

if (!gapClass) {
	throw new Error(`Unsupported ImageMarquee gap "${gap}". Add a Tailwind class mapping.`);
}
---

<div
    class="not-prose overflow-hidden my-12"
    data-marquee
    role="marquee"
    aria-label="Scrolling image gallery"
>
    <div
        class={cn(
            "flex w-max hover:[animation-play-state:paused] motion-reduce:animate-none",
            gapClass,
            animationClass,
        )}
    >
        {
            items.map((img) => (
                img.image ? (
                    <Image
                        src={img.image}
                        alt={img.alt}
                        loading="lazy"
                        class={cn(
                            heights[height],
                            "w-auto rounded-lg object-cover select-none pointer-events-none",
                        )}
                        draggable="false"
                    />
                ) : (
                    <img
                        src={img.src}
                        alt={img.alt}
                        loading="lazy"
                        decoding="async"
                        class={cn(
                            heights[height],
                            "w-auto rounded-lg object-cover select-none pointer-events-none",
                        )}
                        draggable="false"
                    />
                )
            ))
        }
        {
            items.map((img) => (
                img.image ? (
                    <Image
                        src={img.image}
                        alt=""
                        aria-hidden="true"
                        loading="lazy"
                        class={cn(
                            heights[height],
                            "w-auto rounded-lg object-cover select-none pointer-events-none",
                        )}
                        draggable="false"
                    />
                ) : (
                    <img
                        src={img.src}
                        alt=""
                        aria-hidden="true"
                        loading="lazy"
                        decoding="async"
                        class={cn(
                            heights[height],
                            "w-auto rounded-lg object-cover select-none pointer-events-none",
                        )}
                        draggable="false"
                    />
                )
            ))
        }
    </div>
</div>

<script>
    function positionMarquees() {
        const vw = document.documentElement.clientWidth;
        document
            .querySelectorAll<HTMLElement>("[data-marquee]")
            .forEach((el) => {
                el.style.marginLeft = "0";
                el.style.width = "";
                const left = el.getBoundingClientRect().left;
                el.style.width = `${vw}px`;
                el.style.marginLeft = `${-left}px`;
            });
    }
    positionMarquees();
    window.addEventListener("resize", positionMarquees);
</script>

<style>
    @keyframes marquee-scroll {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-50%);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        [data-marquee] .flex {
            animation: none !important;
        }
    }
</style>
