---
import { cn } from "@/lib/cn";

interface Props {
	images: string; // Delimited string: "src|alt,,src|alt"
	speed?: "slow" | "default" | "fast";
	direction?: "left" | "right";
	gap?: string;
	height?: "sm" | "md" | "lg" | "xl";
}

const {
	images: imagesStr,
	speed = "default",
	direction = "left",
	gap = "1rem",
	height = "lg",
} = Astro.props;

const heights: Record<string, string> = {
	sm: "h-32 md:h-40 lg:h-48",
	md: "h-40 md:h-56 lg:h-64",
	lg: "h-48 md:h-64 lg:h-80",
	xl: "h-90 md:h-100 lg:h-160",
};

const items = imagesStr.split(",,").map((entry) => {
	const [src, alt] = entry.split("|");
	return { src: src.trim(), alt: alt?.trim() || "" };
});

const durations: Record<string, string> = {
	slow: "60s",
	default: "35s",
	fast: "20s",
};
const duration = durations[speed];
const animDirection = direction === "right" ? "reverse" : "normal";
---

<div
    class="not-prose overflow-hidden my-12"
    data-marquee
    role="marquee"
    aria-label="Scrolling image gallery"
>
    <div
        class="flex w-max hover:[animation-play-state:paused]"
        style={`gap: ${gap}; animation: marquee-scroll ${duration} linear infinite ${animDirection};`}
    >
        {
            items.map((img) => (
                <img
                    src={img.src}
                    alt={img.alt}
                    loading="lazy"
                    decoding="async"
                    class={cn(
                        heights[height],
                        "w-auto rounded-lg object-cover select-none pointer-events-none",
                    )}
                    draggable="false"
                />
            ))
        }
        {
            items.map((img) => (
                <img
                    src={img.src}
                    alt=""
                    aria-hidden="true"
                    loading="lazy"
                    decoding="async"
                    class={cn(
                        heights[height],
                        "w-auto rounded-lg object-cover select-none pointer-events-none",
                    )}
                    draggable="false"
                />
            ))
        }
    </div>
</div>

<script>
    function positionMarquees() {
        const vw = document.documentElement.clientWidth;
        document
            .querySelectorAll<HTMLElement>("[data-marquee]")
            .forEach((el) => {
                el.style.marginLeft = "0";
                el.style.width = "";
                const left = el.getBoundingClientRect().left;
                el.style.width = `${vw}px`;
                el.style.marginLeft = `${-left}px`;
            });
    }
    positionMarquees();
    window.addEventListener("resize", positionMarquees);
</script>

<style>
    @keyframes marquee-scroll {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-50%);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        [data-marquee] .flex {
            animation: none !important;
        }
    }
</style>
