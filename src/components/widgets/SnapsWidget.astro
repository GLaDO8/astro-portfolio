---
const polaroids = [
	{
		src: "/snaps/DSCF4135-Enhanced-NR-2.webp",
		rotate: 19,
		tx: 300,
		ty: -40,
		fanRotate: 22,
		fanTx: 260,
		fanTy: -50,
	},
	{
		src: "/snaps/DSCF4283.webp",
		rotate: -5,
		tx: 210,
		ty: 15,
		fanRotate: -8,
		fanTx: 155,
		fanTy: 0,
	},
	{
		src: "/snaps/DSCF4449.webp",
		rotate: 26,
		tx: 300,
		ty: 45,
		fanRotate: 32,
		fanTx: 270,
		fanTy: 38,
	},
] as const;
---

<div class="snaps-widget relative h-44 w-90 shrink-0 overflow-visible rounded-2xl bg-[#bdda7d]">
	<div class="flex h-full flex-col p-6">
		<div class="pb-4 font-sans text-xl leading-9 font-bold tracking-[-0.02em] text-[color(display-p3_0.121_0.153_0.016)]">
			Snaps
		</div>
		<div class="font-sans text-lg leading-tight font-medium tracking-[-0.02em] text-[#607139]">
			Poetry from my camera
		</div>
	</div>

	{
		polaroids.map((polaroid, index) => (
			<div
				class="snaps-widget__polaroid absolute top-0 left-0 h-30 w-24 origin-[0%_0%] overflow-hidden bg-white shadow-[0px_4px_18px_2px_rgba(93,93,93,0.25),0px_0px_4px_rgba(0,0,0,0.18)]"
				style={`--snap-rotate:${polaroid.rotate}deg;--snap-x:${polaroid.tx}px;--snap-y:${polaroid.ty}px;--snap-hover-rotate:${polaroid.fanRotate}deg;--snap-hover-x:${polaroid.fanTx}px;--snap-hover-y:${polaroid.fanTy}px;`}
				aria-hidden={index > 0 ? "true" : undefined}
			>
				<div class="m-[5px] h-[86px] w-[86px] overflow-hidden bg-gray-200">
					<img
						src={polaroid.src}
						alt={`Snap ${index + 1}`}
						class="h-full w-full object-cover"
						loading="lazy"
					/>
				</div>
			</div>
		))
	}
</div>

<style>
	.snaps-widget {
		cursor: pointer;
	}

	.snaps-widget__polaroid {
		transform: translate(var(--snap-x), var(--snap-y))
			rotate(var(--snap-rotate));
		transition:
			transform 320ms cubic-bezier(0.22, 1, 0.36, 1),
			opacity 320ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	@media (hover: hover) and (pointer: fine) {
		.snaps-widget:hover .snaps-widget__polaroid {
			transform: translate(var(--snap-hover-x), var(--snap-hover-y))
				rotate(var(--snap-hover-rotate));
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.snaps-widget__polaroid {
			transition-duration: 1ms;
		}
	}
</style>
