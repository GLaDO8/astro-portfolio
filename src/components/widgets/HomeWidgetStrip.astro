---
import type { SongData } from "@/lib/widgetConfig";
import MusicWidget from "./MusicWidget";
import PhotoFrameWidget from "./PhotoFrameWidget";
import SidequestMapWidget from "./SidequestMapWidget";
import SnapsWidget from "./SnapsWidget";

interface Props {
	songData: SongData;
}

const { songData } = Astro.props;
---

<section
    data-home-widget-strip
    class="h-84 w-full overflow-visible pt-8 sm:h-56 md:h-78 md:mt-12"
    aria-label="Personal widgets"
>
    <div
        class="relative left-1/2 grid w-[34rem] origin-top -translate-x-1/2 scale-[0.75] grid-cols-2 items-start justify-items-center gap-x-16 gap-y-16 sm:flex sm:w-max sm:scale-[0.74] sm:justify-between sm:gap-10 md:justify-center md:scale-[0.85] md:gap-12 lg:scale-[1.2] lg:gap-16"
    >
        <div class="justify-self-end rotate-[9deg] sm:justify-self-auto">
            <div data-home-widget class="mt-5 shrink-0">
                <PhotoFrameWidget client:visible />
            </div>
        </div>

        <div class="shrink-0 justify-self-start rotate-[-7deg] sm:justify-self-auto">
            <div data-home-widget>
                <MusicWidget songData={songData} client:visible />
            </div>
        </div>
        <a
            href="/sidequests"
            class="mt-6 block shrink-0 justify-self-end rotate-[6deg] no-underline sm:justify-self-auto"
            aria-label="Open side quests"
        >
            <div data-home-widget>
                <SidequestMapWidget client:visible />
            </div>
        </a>
        <a
            href="/snaps"
            class="-mt-2 block shrink-0 justify-self-start no-underline sm:-ml-10 sm:justify-self-auto"
            aria-label="Open photo roll"
        >
            <div data-home-widget>
                <SnapsWidget client:visible />
            </div>
        </a>
    </div>
</section>

<script>
    import { animate } from "motion/mini";
    import { spring, stagger } from "motion";

    const strip = document.querySelector("[data-home-widget-strip]");
    const widgets = strip?.querySelectorAll("[data-home-widget]") ?? [];

    animate(
        widgets,
        { opacity: [0, 1], transform: ["scale(0.001)", "scale(1)"] },
        {
            delay: stagger(0.09),
            type: spring,
            visualDuration: 0.3,
            bounce: 0.5,
        },
    );
</script>
