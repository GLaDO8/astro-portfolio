---
import type { PhotoFrameData, SongData } from "@/lib/widgetConfig";
import MusicWidget from "./MusicWidget";
import PhotoFrameWidget from "./PhotoFrameWidget.astro";
import SnapsWidget from "./SnapsWidget";

interface Props {
	photoFrame: PhotoFrameData;
	songData: SongData;
}

const { photoFrame, songData } = Astro.props;
---

<section
    class="h-[9.75rem] w-full overflow-visible sm:h-[11rem] md:h-48"
    aria-label="Personal widgets"
>
    <div
        class="relative left-1/2 flex w-max origin-top -translate-x-1/2 scale-[0.6] items-start justify-center gap-3 sm:scale-[0.78] sm:gap-4 md:scale-100 md:gap-10"
    >
        <div class="mt-5 shrink-0 rotate-[9deg]">
            <PhotoFrameWidget
                src={photoFrame.src}
                alt={photoFrame.alt}
            />
        </div>

        <div class="shrink-0 rotate-[-7deg]">
            <MusicWidget songData={songData} client:visible />
        </div>

        <a
            href="/snaps"
            class="-mt-2 -ml-12 block shrink-0 rotate-[10deg] no-underline"
            aria-label="Open photo roll"
        >
            <SnapsWidget client:visible />
        </a>
    </div>
</section>
