---
import type { SongData } from "@/lib/widgetConfig";
import MusicWidget from "./MusicWidget";
import PhotoFrameWidget from "./PhotoFrameWidget";
import SidequestWidget from "./SidequestWidget";
import SnapsWidget from "./SnapsWidget";

interface Props {
    songData: SongData;
}

const { songData } = Astro.props;
---

<section
    data-home-widget-strip
    class="h-84 w-full overflow-visible pt-8 sm:h-112 md:mt-12 md:h-78"
    aria-label="Personal widgets"
>
    <div
        class="place-items-center relative left-1/2 grid w-max origin-top -translate-x-1/2 scale-[0.65] grid-cols-2 items-start gap-x-6 gap-y-8 sm:scale-[0.72] sm:gap-x-8 sm:gap-y-10 md:flex md:scale-[0.92] md:gap-14 lg:scale-[1.02] lg:gap-18 xl:scale-[1.08] xl:gap-32"
    >
        <div class="rotate-[9deg]">
            <div data-home-widget class="mt-5 shrink-0">
                <PhotoFrameWidget client:visible />
            </div>
        </div>

        <div class="shrink-0 rotate-[-7deg]">
            <div data-home-widget>
                <MusicWidget songData={songData} client:visible />
            </div>
        </div>
        <a
            href="/sidequests"
            class="-mt-9 sm:-ml-8 block shrink-0 no-underline md:-mt-14 md:-ml-12"
            aria-label="Open sidequests"
        >
            <div data-home-widget>
                <SidequestWidget client:visible />
            </div>
        </a>
        <a
            href="/snaps"
            class="-ml-10 sm:-mt-5 sm:-ml-10 block shrink-0 no-underline md:-mt-2 md:-ml-14"
            aria-label="Open photo roll"
        >
            <div data-home-widget>
                <SnapsWidget client:visible />
            </div>
        </a>
    </div>
</section>

<script>
    import { animate } from "motion/mini";
    import { spring, stagger } from "motion";

    const strip = document.querySelector("[data-home-widget-strip]");
    const widgets = strip?.querySelectorAll("[data-home-widget]") ?? [];

    animate(
        widgets,
        { opacity: [0, 1], transform: ["scale(0.001)", "scale(1)"] },
        {
            delay: stagger(0.09),
            type: spring,
            visualDuration: 0.3,
            bounce: 0.5,
        },
    );
</script>
