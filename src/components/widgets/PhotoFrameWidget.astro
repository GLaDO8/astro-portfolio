---
import { Image } from "astro:assets";
import postItMe from "@/assets/widgets/postit-me.svg";
import { getImageAsset } from "@/lib/imageAssets";

interface Props {
	src: string;
	alt?: string;
}

const { src, alt = "Photo" } = Astro.props;
const photo = getImageAsset(src);
---

<div class="photo-frame-widget relative h-38 w-38 shrink-0 md:h-48 md:w-48">
    {
        photo ? (
            <Image
                src={photo}
                alt={alt}
                loading="eager"
                class="block h-[84%] w-[84%] -rotate-6 rounded-sm bg-white object-cover p-1.25 shadow-[0_12px_30px_rgba(42,35,29,0.14)]"
            />
        ) : (
            <img
                src={src}
                alt={alt}
                class="block h-[84%] w-[84%] -rotate-6 rounded-sm bg-white object-cover p-1.25 shadow-[0_12px_30px_rgba(42,35,29,0.14)]"
            />
        )
    }
    <div
        class="absolute right-0 -bottom-2 -rotate-8 scale-[0.6] md:scale-[0.75]"
    >
        <Image src={postItMe} alt="Post-it note saying Me!" />
    </div>
</div>

<style>
    .photo-frame-widget {
        transition: transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    @media (hover: hover) and (pointer: fine) {
        .photo-frame-widget:hover {
            transform: rotate(-4deg);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .photo-frame-widget {
            transition-duration: 1ms;
        }
    }
</style>
