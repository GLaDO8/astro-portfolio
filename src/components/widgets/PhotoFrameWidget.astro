---
import { Image } from "astro:assets";
import postItMe from "@/assets/widgets/postit-me.svg";
import { getImageAsset } from "@/lib/imageAssets";

interface Props {
	src: string;
	alt?: string;
	label?: string;
}

const { src, alt = "Photo", label = "Click pls" } = Astro.props;
const photo = getImageAsset(src);
const frameClass = "photo-frame-widget relative h-[10.25rem] w-[10.25rem] shrink-0";
const imageClass =
	"block h-[8.15rem] w-[9.9rem] -rotate-3 rounded-sm bg-white object-cover p-1.25 shadow-[0_12px_30px_rgba(42,35,29,0.14),0_0_4px_rgba(122,122,122,0.18)]";
const postItClass = "absolute -right-4 -bottom-4 -rotate-8 scale-[0.7]";
---

<div class={frameClass}>
    {
        photo ? (
            <Image
                src={photo}
                alt={alt}
                loading="eager"
                class={imageClass}
            />
        ) : (
            <img
                src={src}
                alt={alt}
                class={imageClass}
            />
        )
    }
    <div class={postItClass}>
        <Image src={postItMe} alt="Post-it note saying Me!" />
    </div>
</div>

<style>
    .photo-frame-widget {
        transition: transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    @media (hover: hover) and (pointer: fine) {
        .photo-frame-widget:hover {
            transform: rotate(-4deg);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .photo-frame-widget {
            transition-duration: 1ms;
        }
    }
</style>
