---
import Navbar from "./Navbar.astro";

interface Props {
    currentPath: string;
    containerClass?: string;
    mainClass?: string;
}

const { currentPath, containerClass, mainClass } = Astro.props;
---

<!-- Full-width horizontal borders -->
<div
    class="fixed top-16 inset-x-0 border-b border-fog pointer-events-none z-50"
>
</div>
<div
    class="fixed top-24 inset-x-0 border-b border-fog pointer-events-none z-50"
>
</div>

<div
    class:list={[
        "relative flex max-w-7xl mx-auto min-h-dvh border-fog",
        containerClass,
    ]}
>
    <slot name="sidebar" />

    <div
        class="flex-1 min-w-0 flex flex-col border-x border-fog pt-16"
    >
        <div class="sticky top-16 z-40 bg-parchment">
            <Navbar currentPath={currentPath} />
        </div>
        <main id="main-content" class:list={["flex-1", mainClass]}>
            <slot />
        </main>
    </div>
</div>
