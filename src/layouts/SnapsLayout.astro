---
import Document from "./Document.astro";

interface Props {
	title: string;
	description: string;
	bodyClass?: string;
	class?: string;
	seo?: {
		ogType?: "website" | "article";
		ogImage?: string;
		ogImageAlt?: string;
		article?: {
			publishedTime: string;
		};
		noindex?: boolean;
		jsonLd?: Record<string, unknown>;
	};
}

const { title, description, bodyClass, class: className, seo } = Astro.props;
const mainClass = ["px-5 pb-20", className].filter(Boolean).join(" ");
---

<Document
	title={title}
	description={description}
	bodyClass={bodyClass}
	mainClass={mainClass}
	seo={seo}
>
	<slot />
</Document>
