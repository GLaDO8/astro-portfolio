---
import { Font } from "astro:assets";
import SEO from "@/components/SEO.astro";
import "@/styles/global.css";
import AgentationToolbar from "@/components/AgentationToolbar";

interface Props {
	title: string;
	description: string;
	bodyClass?: string;
	seo?: {
		ogType?: "website" | "article";
		ogImage?: string;
		ogImageAlt?: string;
		article?: {
			publishedTime: string;
		};
		noindex?: boolean;
		jsonLd?: Record<string, unknown>;
	};
}

const { title, description, bodyClass, seo = {} } = Astro.props;
const isDev = import.meta.env.DEV;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <SEO title={title} description={description} {...seo} />
        <Font
            cssVariable="--font-zilla-slab"
            preload={[
                { weight: "600", style: "normal" },
                { weight: "700", style: "normal" },
            ]}
        />
        <Font
            cssVariable="--font-commissioner"
            preload={[{ weight: "400", style: "normal" }]}
        />
        <Font cssVariable="--font-recursive" />
        <script is:inline>
            document.documentElement.dataset.shellTransitions = "true";
        </script>
    </head>
    <body class={bodyClass}>
        <a
            href="#main-content"
            class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:rounded focus:shadow-lg focus:text-charcoal"
            >Skip to content</a
        >
        <slot />
        {isDev && <AgentationToolbar client:only="react" />}

        <script>
            import Lenis from "lenis";

            const lenis = new Lenis({
                lerp: 0.2, // Lower = smoother/slower (0.03–0.2). Set to undefined to use duration instead.
                // duration: 1.2, // Higher = slower. Only used when lerp is undefined.
                smoothWheel: true,
                easing: (t: number) =>
                    Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            });

            function raf(time: number) {
                lenis.raf(time);
                requestAnimationFrame(raf);
            }

            requestAnimationFrame(raf);
        </script>
    </body>
</html>
