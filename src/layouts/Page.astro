---
import Document from "./Document.astro";

interface Props {
	title: string;
	description: string;
	bodyClass?: string;
	class?: string;
	navBlurBackground?: string;
	seo?: {
		ogType?: "website" | "article";
		ogImage?: string;
		ogImageAlt?: string;
		article?: {
			publishedTime: string;
		};
		noindex?: boolean;
		jsonLd?: Record<string, unknown>;
	};
}

const { title, description, bodyClass, class: className, navBlurBackground, seo } = Astro.props;
const mainClass = [
	"grid grid-cols-4 md:grid-cols-12 lg:grid-cols-16 gap-x-4 md:gap-x-5 lg:gap-x-6 px-4 md:px-8 lg:px-12 pt-8 pb-20 content-start",
	className,
]
	.filter(Boolean)
	.join(" ");
---

<Document
	title={title}
	description={description}
	bodyClass={bodyClass}
	mainClass={mainClass}
	navBlurBackground={navBlurBackground}
	seo={seo}
>
	<slot />
</Document>
