---
import Base from "./Base.astro";

interface Props {
    title: string;
    bodyClass?: string;
    class?: string;
}

const { title, bodyClass, class: className } = Astro.props;
---

<Base title={title} bodyClass={bodyClass}>
    <main
        class:list={[
            "grid grid-cols-4 md:grid-cols-12 lg:grid-cols-16 gap-x-4 md:gap-x-5 lg:gap-x-6 px-4 md:px-8 lg:px-12 max-w-[1440px] mx-auto min-h-screen pt-[75px] pb-20 content-start",
            className,
        ]}
    >
        <slot />
    </main>
</Base>
