---
import Navbar from "@/components/Navbar.astro";
import SiteShell from "@/components/SiteShell.astro";
import Base from "./Base.astro";

interface Props {
	title: string;
	description: string;
	bodyClass?: string;
	class?: string;
	seo?: {
		ogType?: "website" | "article";
		ogImage?: string;
		ogImageAlt?: string;
		article?: {
			publishedTime: string;
		};
		noindex?: boolean;
		jsonLd?: Record<string, unknown>;
	};
}

const { title, description, bodyClass, class: className, seo } = Astro.props;
const currentPath = Astro.url.pathname;
const contentColumnClass =
	"col-span-full md:col-span-8 md:col-start-3 lg:col-span-8 lg:col-start-5";

const mainClass = [
	"grid grid-cols-4 md:grid-cols-12 lg:grid-cols-16 gap-x-4 md:gap-x-5 lg:gap-x-6 px-4 md:px-8 lg:px-12 pt-8 pb-20 content-start",
	className,
]
	.filter(Boolean)
	.join(" ");
---

<Base title={title} description={description} bodyClass={bodyClass} seo={seo}>
	<SiteShell mainClass={mainClass}>
		<div
			class:list={[contentColumnClass, "sticky top-4 z-40 mb-12"]}
			data-navbar-shell
		>
			<div transition:persist transition:name="site-navbar">
				<Navbar currentPath={currentPath} />
			</div>
		</div>

		<slot />
	</SiteShell>
</Base>
