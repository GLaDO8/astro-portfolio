---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import Navbar from "@/components/Navbar.astro";
import SEO from "@/components/SEO.astro";
import "@/styles/global.css";
import DevToolbars from "@/components/DevToolbars";

interface Props {
	title: string;
	description: string;
	bodyClass?: string;
	mainClass?: string;
	navClass?: string;
	showNavigation?: boolean;
	seo?: {
		ogType?: "website" | "article";
		ogImage?: string;
		ogImageAlt?: string;
		article?: {
			publishedTime: string;
		};
		noindex?: boolean;
		jsonLd?: Record<string, unknown>;
	};
}

const {
	title,
	description,
	bodyClass,
	mainClass,
	navClass,
	showNavigation = true,
	seo = {},
} = Astro.props;
const isDev = import.meta.env.DEV;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<SEO title={title} description={description} {...seo} />
		<Font
			cssVariable="--font-commissioner"
			preload={[{ weight: "400", style: "normal" }]}
		/>
		<Font cssVariable="--font-recursive" />
		<ClientRouter />
		<script is:inline>
			document.documentElement.dataset.shellTransitions = "true";
		</script>
	</head>
	<body class={bodyClass}>
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:rounded focus:shadow-lg focus:text-charcoal"
			>Skip to content</a
		>
		<div class="relative mx-auto flex min-h-dvh max-w-7xl flex-col">
			{showNavigation && <Navbar currentPath={Astro.url.pathname} class={navClass} />}
			<main
				id="main-content"
				class:list={["min-w-0 flex-1", mainClass]}
				data-shell-content
				data-page-state="entering"
			>
				<slot />
			</main>
		</div>
		{isDev && <DevToolbars client:only="react" />}

		<script>
			const getContent = () =>
				document.querySelector<HTMLElement>("[data-shell-content]");

			const enterContent = () => {
				const content = getContent();

				if (!content) {
					return;
				}

				requestAnimationFrame(() => {
					content.dataset.pageState = "entered";
				});
			};

			const leaveContent = () => {
				const content = getContent();

				if (!content || content.dataset.pageState === "leaving") {
					return;
				}

				content.dataset.pageState = "leaving";
			};

			document.addEventListener("astro:before-preparation", leaveContent);
			document.addEventListener("astro:page-load", enterContent);

			enterContent();
		</script>

		<script>
			import Lenis from "lenis";

			const lenis = new Lenis({
				lerp: 0.2, // Lower = smoother/slower (0.03–0.2). Set to undefined to use duration instead.
				// duration: 1.2, // Higher = slower. Only used when lerp is undefined.
				smoothWheel: true,
				easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
			});

			function raf(time: number) {
				lenis.raf(time);
				requestAnimationFrame(raf);
			}

			requestAnimationFrame(raf);
		</script>
	</body>
</html>
