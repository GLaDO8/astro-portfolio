---
import NoonPortfolioButton from "@/components/NoonPortfolioButton";
import Document from "@/layouts/Document.astro";

const pitchLinkClass =
	"font-semibold underline decoration-2 decoration-dotted underline-offset-4 transition-opacity hover:opacity-75";

const quotes = [
	{
		name: "KV Ketan",
		role: "Head of Design, Wayground",
		initials: "KV",
		photo: "/noon/ketan.jpeg",
		quote: "You are genuinely one of the smartest and caring designer I have met.",
		linkedin: "https://www.linkedin.com/in/kvketan/",
	},
	{
		name: "Varun Banka",
		role: "Founder, Atlan",
		initials: "VB",
		photo: "/noon/varun.jpeg",
		quote: "Love how you do your demos, I'm going to steal how you start them. Love the 120%.",
		linkedin: "https://www.linkedin.com/in/varunbanka/",
	},
	{
		name: "Shekh Ali",
		role: "Engineer, Atlan",
		initials: "SA",
		photo: "/noon/ali.jpeg",
		quote:
			"One thing I have picked up from Shreyas is - No matter how long it takes, fixing paper cuts like small subtle interactions and bugs make so much difference.",
		linkedin: "https://www.linkedin.com/in/shekh-aliul/",
	},
	{
		name: "Ankita",
		role: "PM, Clari",
		initials: "A",
		photo: "/noon/ankita.jpeg",
		quote: "Shreyas, It warms my heart to see how you leverage data in your design process.",
		linkedin: "https://www.linkedin.com/in/ankta/",
	},
	{
		name: "Vaidehi Dalmia",
		role: "PM at Atlan",
		initials: "VD",
		photo: "/noon/vaidehi.jpeg",
		quote:
			"I just wanted to say how inspired I have been by your bias for action and fearlessness to question! Thank you for continously raising the PM-design bar.",
		linkedin: "https://www.linkedin.com/in/vaidehidalmia/",
	},
	{
		name: "Aman Awasthy",
		role: "Sr. Product Designer, Wayground",
		initials: "AA",
		photo: "/noon/aman.jpeg",
		quote:
			"The level of curiosity you harbor is inspiring, very iconoclastic personality and quite an expert at everything you do.",
		linkedin: "https://www.linkedin.com/in/aman-awasthy-74986971/",
	},
	{
		name: "Chinmay Joshi",
		role: "Engineering Manager, Wayground",
		initials: "CJ",
		photo: "/noon/chinmay.jpeg",
		quote: "Shreyas, what are you buddy? Designer, presenter, developer, PM, more like everything!",
		linkedin: "https://www.linkedin.com/in/chinmayjoshi94/",
	},
	{
		name: "Darshita Patankar",
		role: "Visual Designer, Wayground",
		initials: "DP",
		photo: "/noon/darshita.jpeg",
		quote:
			"Your design sense and craft really inspires me, to always ask the deeper questions, the depth of opinion and clarity you bring, looking at design beyond screens.",
		linkedin: "https://www.linkedin.com/in/darshitapatankar/",
	},
	{
		name: "Anonymous feedback",
		role: "Atlan",
		initials: "AN",
		quote:
			"Shreyas has consistently given his 120% to any product areas or modules he owns AND made contributions to both company and design team culture. He pushes himself and the rest of the team to adopt better design practices, & doesn't shy away from sharing feedback when he feels something isn't working.",
	},
	{
		name: "Suyash Agarwal",
		role: "Product Designer, Wayground",
		initials: "SA",
		photo: "/noon/suyash.jpeg",
		quote:
			"You had this way of cutting through the noise in design reviews. While everyone else would go off on tangents, you'd bring it back to the core by asking simple but sharp questions. It forced everyone to pause and actually think about the decisions we were making.",
		linkedin: "https://www.linkedin.com/in/suyashagarwal01/",
	},
];

const shouldShowAvatar = (person: (typeof quotes)[number]) => !person.name.startsWith("Anonymous");
const anonymousQuotes = quotes.filter((person) => !shouldShowAvatar(person));
const namedQuotes = quotes.filter(shouldShowAvatar);
const quoteColumns = [0, 1].map((columnIndex) => [
	...namedQuotes.filter((_, index) => index % 2 === columnIndex),
	...(columnIndex === 1 ? anonymousQuotes : []),
]);
---

<Document
    title="Noon Design — Shreyas Gupta"
    description="A short pitch to Noon Design from Shreyas Gupta."
    bodyClass="bg-beige"
    mainClass="bg-beige px-4 py-12 md:py-20"
    showNavigation={false}
    showFooter={false}
>
    <article class="mx-auto flex w-full max-w-5xl flex-col gap-14">
        <section>
            <div
                class="text-pretty font-sans text-lg leading-[1.7] font-medium tracking-[-0.02em] text-primary md:text-2xl md:px-48 pt-8"
            >
                <p>Hey Noon team,</p>
                <br />
                <p>
                    Let me give you a no fluff version of who I am and how I operate. I've
                    been a tinkerer for more than a decade, you can see it in the
                    <a
                        href="https://www.raycast.com/GLaDO8"
                        target="_blank"
                        rel="noopener noreferrer"
                        class={pitchLinkClass}>Raycast extensions</a
                    >
                    I have built like Figma File Search (I'm guessing at least one of you have
                    used it), endless optimisations to how I work through my
                    <a
                        href="https://github.com/GLaDO8/dotfiles"
                        target="_blank"
                        rel="noopener noreferrer"
                        class={pitchLinkClass}>dotfiles</a
                    >
                    or just my
                    <a
                        href="https://github.com/GLaDO8"
                        target="_blank"
                        rel="noopener noreferrer"
                        class={pitchLinkClass}>Github profile</a
                    >.
                </p>
                <br />
                <p>
                    I have exercised and built my taste through photography, 3D printing,
                    DJing and building things. Throughout this journey, I have embraced a
                    million tools to realise my ideas, and I am reaching out to be a part
                    of building the next generation of design tooling.
                </p>
                <br />
                <p>
                    I embody the idea that you can learn anything in due time and operate
                    as a high-functioning generalist.
                </p>
                <br />
                <p>
                    I'll let my peers speak for me, please feel free to reach out to them.
                    (These are excerpts from my "Kudos" Figma file with all the feedback
                    I've received).
                </p>
                <br />
                <p>
                    Excited to talk to you folks about the role! Also, Website's still
                    very WIP, but I wanted to start a conversation.
                </p>
            </div>
        </section>

        <section class="grid gap-4 md:grid-cols-2 md:items-start">
            {
                quoteColumns.map((column) => (
                    <div class="flex flex-col gap-4">
                        {column.map((person) => (
                            <figure class="relative flex w-full flex-col justify-between gap-8 rounded-md border border-black/8 bg-white p-5 shadow-xs">
                                <blockquote class="text-pretty font-sans text-lg leading-[1.7] font-medium text-primary md:text-xl">
                                    "{person.quote}"
                                </blockquote>

                                <figcaption class="flex items-center gap-3">
                                    {shouldShowAvatar(person) && person.photo ? (
                                        <div class="relative size-10 shrink-0">
                                            <div class="flex size-10 items-center justify-center rounded-full border border-black/8 bg-[#faffff] font-sans text-sm font-bold text-primary">
                                                {person.initials}
                                            </div>
                                            <img
                                                src={person.photo}
                                                alt=""
                                                loading="lazy"
                                                decoding="async"
                                                onerror="this.remove()"
                                                class="absolute inset-0 size-10 rounded-full border border-black/8 object-cover"
                                            />
                                        </div>
                                    ) : shouldShowAvatar(person) ? (
                                        <div class="flex size-10 shrink-0 items-center justify-center rounded-full border border-black/8 bg-[#faffff] font-sans text-sm font-bold text-primary">
                                            {person.initials}
                                        </div>
                                    ) : null}
                                    <div class="min-w-0">
                                        <p class="font-sans text-base font-bold leading-tight text-primary">
                                            {person.name}
                                        </p>
                                        <p class="font-sans text-base leading-snug text-secondary">
                                            {person.role}
                                        </p>
                                    </div>
                                </figcaption>
                                {person.linkedin && (
                                    <a
                                        href={person.linkedin}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        aria-label={`${person.name} on LinkedIn`}
                                        class="absolute right-5 bottom-5 inline-flex size-8 items-center justify-center rounded-full text-primary/70 transition-colors hover:text-primary"
                                    >
                                        <svg
                                            viewBox="0 0 24 24"
                                            fill="currentColor"
                                            class="size-4"
                                            aria-hidden="true"
                                        >
                                            <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.61 0 4.28 2.38 4.28 5.47v6.27h-.02ZM5.32 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12Zm1.78 13.02H3.54V9H7.1v11.45ZM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0Z" />
                                        </svg>
                                    </a>
                                )}
                            </figure>
                        ))}
                    </div>
                ))
            }
        </section>

        <section
            class="mx-auto flex w-full max-w-3xl flex-col items-center pt-2 text-center"
        >
            <NoonPortfolioButton href="/" client:visible
                >Go to portfolio</NoonPortfolioButton
            >
        </section>
    </article>
</Document>
