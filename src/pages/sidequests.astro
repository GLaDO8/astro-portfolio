---
import Page from "@/layouts/Page.astro";

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	name: "Sidequests",
	description: "Side projects, prototypes, and experiments by Shreyas Gupta.",
	url: "https://shrey.fyi/sidequests",
};
---

<Page
    title="Sidequests — Shreyas Gupta"
    description="Side projects, prototypes, and experiments by Shreyas Gupta."
    bodyClass="bg-beige"
    class="bg-beige"
    seo={{ jsonLd }}
>
    <section
        class="col-span-full md:col-span-8 md:col-start-3 lg:col-span-8 lg:col-start-5"
    >
        <header class="mt-8">
            <h1
                class="font-sans text-4xl leading-[1.1] font-bold tracking-[-0.03em] text-primary text-balance md:text-5xl"
            >
                Sidequests
            </h1>
            <p class="mt-4 max-w-2xl font-sans text-base leading-relaxed text-secondary md:text-lg">
                Side projects, prototypes, and playful builds.
            </p>
        </header>
    </section>
</Page>
