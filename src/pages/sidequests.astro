---
import aeropressStandModelUrl from "@/assets/sidequests/aeropress-stand.glb?url";
import v60StandModelUrl from "@/assets/sidequests/v60-stand.glb?url";
import CADRender, { type CADModel } from "@/components/sidequests/CADRender";
import SidequestsCanvas from "@/components/sidequests/SidequestsCanvas";
import Document from "@/layouts/Document.astro";

const cadModels = [
	{
		id: "v60-skadis",
		src: v60StandModelUrl,
		alt: "Rotating white 3D model of a V60 Skadis mount",
	},
	{
		id: "aeropress-skadis-stand",
		src: aeropressStandModelUrl,
		alt: "Rotating white 3D model of an Aeropress Skadis stand",
	},
] satisfies CADModel[];

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	name: "Sidequests",
	description: "Side projects, prototypes, and experiments by Shreyas Gupta.",
	url: "https://shrey.fyi/sidequests",
};
---

<Document
	title="Sidequests — Shreyas Gupta"
	description="Side projects, prototypes, and experiments by Shreyas Gupta."
	bodyClass="overflow-hidden bg-beige"
	mainClass="relative block h-dvh min-h-dvh overflow-hidden bg-beige"
	navClass="fixed top-4 left-1/2 z-40 mb-0 w-[min(calc(100%_-_2rem),39.25rem)] max-w-[calc(100%_-_2rem)] -translate-x-1/2"
	constrainShell={false}
	seo={{ jsonLd }}
>
	<SidequestsCanvas client:load>
		<header
			class="absolute top-[calc(50%_-_21rem)] left-[calc(50%_-_11rem)] max-w-[22rem] select-text px-4 md:top-[calc(50%_-_13rem)] md:left-[calc(50%_-_30rem)] md:max-w-md"
		>
			<h1
				class="font-sans text-4xl leading-[1.1] font-bold tracking-[-0.03em] text-primary text-balance md:text-5xl"
			>
				Sidequests
			</h1>
			<p
				class="mt-4 max-w-2xl font-sans text-base leading-relaxed text-secondary md:text-lg"
			>
				Side projects, prototypes, and playful builds.
			</p>
		</header>

		<div
			class="absolute top-[calc(50%_-_10rem)] left-[calc(50%_-_9.5rem)] grid grid-cols-[minmax(15rem,19rem)] gap-5 md:top-[calc(50%_-_5.5rem)] md:left-[calc(50%_+_2rem)] md:grid-cols-[repeat(2,minmax(14rem,18rem))] md:gap-6"
		>
			{cadModels.map((model) => <CADRender model={model} />)}
		</div>
	</SidequestsCanvas>
</Document>
