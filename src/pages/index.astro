---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import hotTextImage from "@/assets/work/hottext.png";
import labelingImage from "@/assets/work/labeling.png";
import whistleImage from "@/assets/work/whistl.png";
import HeroSection from "@/components/HeroSection";
import HomeWidgetStrip from "@/components/widgets/HomeWidgetStrip.astro";
import HeroGoogleFontSwapWidget from "@/dev/HeroGoogleFontSwapWidget";
import Page from "@/layouts/Page.astro";
import { getSongData } from "@/lib/widgetConfig";

const homeTextColumn = "col-span-full md:col-span-10 md:col-start-2 lg:col-span-10 lg:col-start-4";
const homeWidgetColumn =
	"col-span-full md:col-span-10 md:col-start-2 lg:col-span-12 lg:col-start-3";
const homeWorkColumn = "col-span-full";
const songData = await getSongData();
const homeStudyOrder = ["labelling", "hot-text", "one-more-whistle"];
const studies = (await getCollection("caseStudies"))
	.filter((study) => homeStudyOrder.includes(study.id))
	.sort((a, b) => homeStudyOrder.indexOf(a.id) - homeStudyOrder.indexOf(b.id));
const enableHeroFontSwap = import.meta.env.DEV;
const homeDescriptionLinkClass =
	"font-semibold underline decoration-2 decoration-dotted underline-offset-3 transition-opacity hover:opacity-75";
const workImages = {
	"hot-text": {
		src: hotTextImage,
		alt: "Highlighted hot text question prototype on a pink background.",
	},
	labelling: {
		src: labelingImage,
		alt: "Interactive labeling question prototype over a heart diagram.",
	},
	"one-more-whistle": {
		src: whistleImage,
		alt: "Whistl pressure cooker whistle counter app screen.",
	},
} as const;

const jsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebSite",
			"@id": "https://shrey.fyi/#website",
			url: "https://shrey.fyi",
			name: "Shreyas Gupta",
			description:
				"Designer, mushroom grower, and cat dad. Writing about design, technology, and everyday systems.",
			publisher: { "@id": "https://shrey.fyi/#person" },
		},
		{
			"@type": "Person",
			"@id": "https://shrey.fyi/#person",
			name: "Shreyas Gupta",
			url: "https://shrey.fyi",
			jobTitle: "Designer",
			sameAs: ["https://github.com/GLaDO8", "https://x.com/wutamelonshrey"],
		},
	],
};
---

<Page
    title="Shreyas Gupta — Designer"
    description="Designer, mushroom grower, and cat dad. Writing about design, technology, and everyday systems."
    bodyClass="bg-beige"
    class="bg-beige gap-y-12"
    seo={{ jsonLd }}
>
    <div class:list={[homeWidgetColumn, "min-w-0"]}>
        <HomeWidgetStrip songData={songData} />
    </div>

    <div class:list={[homeTextColumn, "flex min-w-0 flex-col items-center gap-9"]}>
        <HeroSection client:visible />
        {enableHeroFontSwap && <HeroGoogleFontSwapWidget client:load />}

        <div
            class="text-pretty font-sans text-lg leading-[1.7] font-medium tracking-[-0.02em] text-primary md:text-xl md:px-16 pt-8"
        >
            <p class="text-pretty">
                I’ve spent the last 5 years working on and beyond the visible interface of
                products across domains like ed-tech, data and enterprise sales.
            </p>
            <br />
            <p class="text-pretty">
                I embody the idea that you can learn anything in due time and operate as a
                high-functioning generalist. Currently rabbitholing Mycology, emergent
                systems, D2C and CAD modeling.
            </p>
            <br />
            <p class="text-pretty">
                Previously Sr. Product Designer at <a
                    href="https://wayground.com/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class={homeDescriptionLinkClass}>Wayground/Quizizz</a
                >, where I worked on AI creator tools for teachers. Before that, I built a
                context-aware SQL editor at
                <a
                    href="https://atlan.com/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class={homeDescriptionLinkClass}>Atlan</a
                >. Find all my past roles <a
                    href="https://www.linkedin.com/in/shreyas-gupta/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class={homeDescriptionLinkClass}>here</a
                >. Open for client work, shoot a <a
                    href="https://x.com/wutamelonshrey"
                    target="_blank"
                    rel="noopener noreferrer"
                    class={homeDescriptionLinkClass}>DM</a
                > or send an <a
                    href="mailto:gshreyas@icloud.com"
                    target="_blank"
                    rel="noopener noreferrer"
                    class={homeDescriptionLinkClass}>email</a
                >.
            </p>
        </div>
    </div>

    <section
        class:list={[homeWorkColumn, "min-w-0 pt-12"]}
        aria-labelledby="work-heading"
    >
        <h2 id="work-heading" class="sr-only">Work</h2>

        <div class="grid grid-cols-1 gap-x-7 gap-y-10 md:grid-cols-3">
            {
                studies.map((study) => {
                    const image = workImages[study.id as keyof typeof workImages];

                    return (
                        <a
                            href={`/work/${study.id}`}
                            class="group block min-w-0 text-primary no-underline transition-transform duration-200 hover:-translate-y-1"
                        >
                            {image && (
                                <Image
                                    src={image.src}
                                    alt={image.alt}
                                    widths={[420, 640, 840, 1200]}
                                    sizes="(min-width: 768px) 28vw, 92vw"
                                    class="block h-auto w-full"
                                />
                            )}

                            <p class="mt-4 font-sans text-base leading-none font-semibold text-secondary">
                                {study.data.projectType}
                            </p>
                            <h3 class="mt-2 font-sans text-2xl leading-[1.05] font-bold tracking-[-0.04em] text-balance text-primary">
                                {study.data.title}
                            </h3>
                        </a>
                    );
                })
            }
        </div>
    </section>
</Page>
