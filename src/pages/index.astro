---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import hotTextImage from "@/assets/case-studies/hottext/Frame@2x.webp";
import labelingImage from "@/assets/case-studies/labeling/labeling-working.webp";
import whistleImage from "@/assets/case-studies/one-more-whistle/whistl-main-screens.png";
import HeroSection from "@/components/HeroSection";
import HomeWidgetStrip from "@/components/widgets/HomeWidgetStrip.astro";
import HeroGoogleFontSwapWidget from "@/dev/HeroGoogleFontSwapWidget";
import Page from "@/layouts/Page.astro";
import { getSongData } from "@/lib/widgetConfig";

const homeTextColumn =
    "col-span-full md:col-span-10 md:col-start-2 lg:col-span-10 lg:col-start-4";
const homeWidgetColumn =
    "col-span-full md:col-span-10 md:col-start-2 lg:col-span-12 lg:col-start-3";
const homeWorkColumn =
    "col-span-full md:col-span-10 md:col-start-2 lg:col-span-12 lg:col-start-3";
const songData = await getSongData();
const studies = (await getCollection("caseStudies"))
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
    .filter((study) => study.id !== "wayground-creation");
const enableHeroFontSwap = import.meta.env.DEV;
const homeDescriptionLinkClass =
    "font-semibold underline decoration-2 decoration-dotted underline-offset-3 transition-opacity hover:opacity-75";
const workImages = {
    "hot-text": {
        src: hotTextImage,
        alt: "Paper card with highlighted text on a pink background.",
    },
    labelling: {
        src: labelingImage,
        alt: "Labeling question interface with draggable labels.",
    },
    "one-more-whistle": {
        src: whistleImage,
        alt: "Mobile app screens for the pressure cooker whistle counter prototype.",
    },
} as const;

const jsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "WebSite",
            "@id": "https://shrey.fyi/#website",
            url: "https://shrey.fyi",
            name: "Shreyas Gupta",
            description:
                "Designer, mushroom grower, and cat dad. Writing about design, technology, and everyday systems.",
            publisher: { "@id": "https://shrey.fyi/#person" },
        },
        {
            "@type": "Person",
            "@id": "https://shrey.fyi/#person",
            name: "Shreyas Gupta",
            url: "https://shrey.fyi",
            jobTitle: "Designer",
            sameAs: ["https://github.com/GLaDO8", "https://x.com/wutamelonshrey"],
        },
    ],
};
---

<Page
    title="Shreyas Gupta — Designer"
    description="Designer, mushroom grower, and cat dad. Writing about design, technology, and everyday systems."
    bodyClass="bg-beige"
    class="bg-beige gap-y-12"
    seo={{ jsonLd }}
>
    <div class:list={[homeWidgetColumn, "min-w-0"]}>
        <HomeWidgetStrip songData={songData} />
    </div>

    <div class:list={[homeTextColumn, "flex min-w-0 flex-col items-center gap-9"]}>
        <HeroSection client:visible />
        {enableHeroFontSwap && <HeroGoogleFontSwapWidget client:load />}

        <div
            class="text-pretty font-sans text-lg leading-[1.7] font-medium tracking-[-0.02em] text-primary md:text-xl md:px-16 pt-8"
        >
            <p class="text-pretty">
                I’ve spent the last 5 years working on and beyond the visible interface of
                products across domains like ed-tech, data and enterprise sales.
            </p>
            <br />
            <p class="text-pretty">
                I embody the idea that you can learn anything in due time and operate as a
                high-functioning generalist. Currently rabbitholing Mycology, emergent
                systems, D2C and CAD modeling.
            </p>
            <br />
            <p class="text-pretty">
                Previously Sr. Product Designer at <a
                    href="https://wayground.com/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class={homeDescriptionLinkClass}>Wayground/Quizizz</a
                >, where I worked on AI creator tools for teachers. Before that, I built a
                context-aware SQL editor at
                <a
                    href="https://atlan.com/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class={homeDescriptionLinkClass}>Atlan</a
                >. Find all my past roles <a
                    href="https://www.linkedin.com/in/shreyas-gupta/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class={homeDescriptionLinkClass}>here</a
                >. Open for client work, shoot a <a
                    href="https://x.com/wutamelonshrey"
                    target="_blank"
                    rel="noopener noreferrer"
                    class={homeDescriptionLinkClass}>DM</a
                > or send an <a
                    href="mailto:gshreyas@icloud.com"
                    target="_blank"
                    rel="noopener noreferrer"
                    class={homeDescriptionLinkClass}>email</a
                >.
            </p>
        </div>
    </div>

    <section
        class:list={[homeWorkColumn, "min-w-0 pt-12"]}
        aria-labelledby="work-heading"
    >
        <div class="mb-6 text-center">
            <div>
                <h2
                    id="work-heading"
                    class="font-sans text-xl leading-none font-bold tracking-[-0.03em] text-primary md:text-lg"
                >
                    WORK
                </h2>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
            {
                studies.map((study) => {
                    const image = workImages[study.id as keyof typeof workImages];

                    return (
                        <a
                            href={`/work/${study.id}`}
                            class="receipt-card group relative flex min-h-[30rem] flex-col bg-white px-5 pt-8 pb-9 text-primary no-underline transition-transform duration-200 hover:-translate-y-1 lg:px-6 lg:pt-9 lg:pb-10"
                        >
                            <div class="mb-5 border-b border-dashed border-primary/25 pb-4">
                                <p class="font-sans text-xs leading-none font-medium tracking-[0.08em] text-secondary uppercase">
                                    {study.data.date.toLocaleDateString("en-US", {
                                        year: "numeric",
                                        month: "short",
                                    })}
                                </p>
                                <h3 class="mt-3 font-sans text-2xl leading-[1.02] font-bold tracking-[-0.045em] text-balance text-primary">
                                    {study.data.title}
                                </h3>
                            </div>

                            {image && (
                                <div class="relative mb-5 aspect-[4/3] overflow-hidden bg-tertiary/30">
                                    <Image
                                        src={image.src}
                                        alt={image.alt}
                                        widths={[360, 520, 720, 900]}
                                        sizes="(min-width: 768px) 28vw, 92vw"
                                        class="h-full w-full object-cover"
                                    />
                                </div>
                            )}

                            <div class="mt-auto flex justify-end pt-5">
                                <span
                                    aria-hidden="true"
                                    class="flex size-6 items-center justify-center text-secondary transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                                >
                                    <svg
                                        viewBox="0 0 16 16"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="1.8"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="size-5"
                                    >
                                        <path d="M5 11L11 5" />
                                        <path d="M6 5H11V10" />
                                    </svg>
                                </span>
                            </div>
                        </a>
                    );
                })
            }
        </div>
    </section>
</Page>

