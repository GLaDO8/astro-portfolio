---
import HeroSection from "@/components/HeroSection";
import HomeWidgetStrip from "@/components/widgets/HomeWidgetStrip.astro";
import Page from "@/layouts/Page.astro";
import { getSongData } from "@/lib/widgetConfig";

const homeTextColumn = "col-span-full md:col-span-8 md:col-start-3 lg:col-span-8 lg:col-start-5";
const homeWidgetColumn =
	"col-span-full md:col-span-10 md:col-start-2 lg:col-span-12 lg:col-start-3";
const songData = await getSongData();

const jsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebSite",
			"@id": "https://shrey.fyi/#website",
			url: "https://shrey.fyi",
			name: "Shreyas Gupta",
			description:
				"Designer, mushroom grower, and cat dad. Writing about design, technology, and everyday systems.",
			publisher: { "@id": "https://shrey.fyi/#person" },
		},
		{
			"@type": "Person",
			"@id": "https://shrey.fyi/#person",
			name: "Shreyas Gupta",
			url: "https://shrey.fyi",
			jobTitle: "Designer",
			sameAs: ["https://github.com/GLaDO8", "https://x.com/wutamelonshrey"],
		},
	],
};
---

<Page
    title="Shreyas Gupta — Designer"
    description="Designer, mushroom grower, and cat dad. Writing about design, technology, and everyday systems."
    bodyClass="bg-parchment"
    class="bg-parchment gap-y-12"
    seo={{ jsonLd }}
>
    <div class:list={[homeWidgetColumn, "min-w-0"]}>
        <HomeWidgetStrip songData={songData} />
    </div>

    <div class:list={[homeTextColumn, "flex min-w-0 flex-col items-center gap-9"]}>
        <HeroSection client:visible />

        <div
            class="text-pretty text-center font-sans text-lg leading-[1.8] font-medium tracking-[-0.02em] text-charcoal"
        >
            <p class="text-pretty">
                I build tools at <a
                    href="https://wayground.com/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline decoration-2 underline-offset-2 transition-colors hover:opacity-85"
                    >Wayground</a
                > that stand between teachers and everything else that isn't teaching. I used
                to work on conversational intelligence for sales teams at <a
                    href="https://www.clari.com/products/copilot/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline decoration-2 underline-offset-2 transition-colors hover:opacity-85"
                    >Clari</a
                > and built a context-rich SQL editor at
                <a
                    href="https://atlan.com/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline decoration-2 underline-offset-2 transition-colors hover:opacity-85"
                    >Atlan</a
                >.
            </p>
        </div>
    </div>
</Page>
