---
import HeroSection from "@/components/HeroSection";
import HomeWidgetStrip from "@/components/widgets/HomeWidgetStrip.astro";
import HeroGoogleFontSwapWidget from "@/dev/HeroGoogleFontSwapWidget";
import Page from "@/layouts/Page.astro";
import { getSongData } from "@/lib/widgetConfig";

const homeTextColumn =
    "col-span-full md:col-span-10 md:col-start-2 lg:col-span-10 lg:col-start-4";
const homeWidgetColumn =
    "col-span-full md:col-span-10 md:col-start-2 lg:col-span-12 lg:col-start-3";
const songData = await getSongData();
const enableHeroFontSwap = import.meta.env.DEV;

const jsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "WebSite",
            "@id": "https://shrey.fyi/#website",
            url: "https://shrey.fyi",
            name: "Shreyas Gupta",
            description:
                "Designer, mushroom grower, and cat dad. Writing about design, technology, and everyday systems.",
            publisher: { "@id": "https://shrey.fyi/#person" },
        },
        {
            "@type": "Person",
            "@id": "https://shrey.fyi/#person",
            name: "Shreyas Gupta",
            url: "https://shrey.fyi",
            jobTitle: "Designer",
            sameAs: ["https://github.com/GLaDO8", "https://x.com/wutamelonshrey"],
        },
    ],
};
---

<Page
    title="Shreyas Gupta — Designer"
    description="Designer, mushroom grower, and cat dad. Writing about design, technology, and everyday systems."
    bodyClass="bg-beige"
    class="bg-beige gap-y-12"
    seo={{ jsonLd }}
>
    <div class:list={[homeWidgetColumn, "min-w-0"]}>
        <HomeWidgetStrip songData={songData} />
    </div>

    <div class:list={[homeTextColumn, "flex min-w-0 flex-col items-center gap-9"]}>
        <HeroSection client:visible />
        {enableHeroFontSwap && <HeroGoogleFontSwapWidget client:load />}

        <div
            class="text-pretty font-sans text-lg leading-[1.7] font-medium tracking-[-0.02em] text-primary md:text-xl md:px-16 pt-8"
        >
            <p class="text-pretty">
                I’ve spent the last 5 years working on and beyond the visible interface of
                products across domains like ed-tech, data and enterprise sales.
            </p>
            <br />
            <p class="text-pretty">
                I embody the idea that you can learn anything in due time and operate as a
                high-functioning generalist. Currently rabbitholing Mycology, emergent
                systems, D2C and CAD modeling.
            </p>
            <br />
            <p class="text-pretty">
                Previously Sr. Product Designer at <a
                    href="https://wayground.com/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline decoration-3 decoration-dotted underline-offset-4 transition-colors hover:opacity-85 font-semibold"
                    >Wayground/Quizizz</a
                >, where I worked on AI creator tools for teachers. Before that, I built a
                context-aware SQL editor at
                <a
                    href="https://atlan.com/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline decoration-3 decoration-dotted underline-offset-4 transition-colors hover:opacity-85 font-semibold"
                    >Atlan</a
                >. Find all my past roles <a
                    href="https://www.linkedin.com/in/shreyas-gupta/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline decoration-3 decoration-dotted underline-offset-4 transition-colors hover:opacity-85 font-semibold"
                    >here</a
                >. Open for client work, shoot a <a
                    href="https://x.com/wutamelonshrey"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline decoration-3 decoration-dotted underline-offset-4 transition-colors hover:opacity-85 font-semibold"
                    >DM</a
                > or send an <a
                    href="mailto:gshreyas@icloud.com"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline decoration-3 decoration-dotted underline-offset-4 transition-colors hover:opacity-85 font-semibold"
                    >email</a
                >.
            </p>
        </div>
    </div>
</Page>
