---
import { getCollection } from "astro:content";
import HeroSection from "@/components/HeroSection";
import SiteShell from "@/components/SiteShell.astro";
import MusicWidget from "@/components/widgets/MusicWidget";
import PhotoFrameWidget from "@/components/widgets/PhotoFrameWidget.astro";
import SnapsWidget from "@/components/widgets/SnapsWidget.astro";
import Base from "@/layouts/Base.astro";
import { getSongData, getWidgetConfig } from "@/lib/widgetConfig";

const notes = (await getCollection("notes", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const caseStudies = (
    await getCollection("caseStudies", ({ data }) => !data.draft)
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const widgetConfig = getWidgetConfig();
const photoFrame = widgetConfig.photoframe;
const songData = await getSongData();

const featuredStudy = caseStudies[0];
const heroNotes = notes.slice(0, 5);

const jsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "WebSite",
            "@id": "https://shrey.fyi/#website",
            url: "https://shrey.fyi",
            name: "Shreyas Gupta",
            description:
                "Designer, mushroom grower, and cat dad. Writing about design, technology, and everyday systems.",
            publisher: { "@id": "https://shrey.fyi/#person" },
        },
        {
            "@type": "Person",
            "@id": "https://shrey.fyi/#person",
            name: "Shreyas Gupta",
            url: "https://shrey.fyi",
            jobTitle: "Designer",
            sameAs: [
                "https://github.com/GLaDO8",
                "https://x.com/wutamelonshrey",
            ],
        },
    ],
};
---

<Base
    title="Shreyas Gupta — Designer"
    description="Designer, mushroom grower, and cat dad. Writing about design, technology, and everyday systems."
    bodyClass="bg-parchment"
    seo={{ jsonLd }}
>
    <SiteShell currentPath="/" mainClass="px-0">
        <div
            class="grid gap-14 lg:grid-cols-[minmax(0,22rem)_minmax(0,1fr)] xl:grid-cols-[minmax(0,24rem)_minmax(0,1fr)] xl:gap-22"
        >
            <aside
                class="flex flex-col gap-8 xl:sticky xl:top-6 xl:self-start pt-8"
            >
                <PhotoFrameWidget src={photoFrame.src} alt={photoFrame.alt} />

                <HeroSection client:visible />

                <div
                    class="max-w-120 font-sans text-base leading-[1.42] font-medium tracking-[-0.02em] text-charcoal"
                >
                    <p class="text-pretty">
                        I build tools at <a
                            href="https://wayground.com/"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="underline decoration-2 underline-offset-3 transition-colors hover:text-slate"
                            >Wayground</a
                        > that stand between teachers and everything else that isn't
                        teaching.
                    </p>
                    <p class="mt-7 text-pretty">
                        I used to work on conversational intelligence for sales
                        teams at <a
                            href="https://www.clari.com/products/copilot/"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="underline decoration-2 underline-offset-3 transition-colors hover:text-slate"
                            >Clari</a
                        > and built a context-rich SQL editor at
                        <a
                            href="https://atlan.com/"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="underline decoration-2 underline-offset-3 transition-colors hover:text-slate"
                            >Atlan</a
                        >.
                    </p>
                </div>

                <!-- <PromptCard client:load /> -->
            </aside>

            <div class="flex min-w-0 flex-col gap-16">
                <section id="work" class="flex flex-col gap-5">
                    <p
                        class="font-sans text-sm font-medium tracking-[-0.02em] text-slate"
                    >
                        Selected Work &amp; Experiments
                    </p>

                    <div class="grid auto-rows-[12.5rem] gap-5 lg:grid-cols-2">
                        {
                            featuredStudy && (
                                <a
                                    href={`/case-studies/${featuredStudy.id}`}
                                    class="group relative row-span-2 min-h-[28rem] overflow-hidden rounded-[1.6rem] bg-[#eb67bb] p-7 no-underline shadow-[inset_0_0_0_1px_rgba(167,53,126,0.08),0_16px_34px_rgba(42,35,29,0.1)]"
                                >
                                    <div class="max-w-[13ch]">
                                        <h2 class="font-serif text-[1.95rem] leading-[0.98] font-semibold tracking-[-0.04em] text-charcoal lg:text-[2.45rem]">
                                            {featuredStudy.data.title}
                                        </h2>
                                    </div>

                                    <img
                                        src="/cs-card-1.png"
                                        alt=""
                                        class="absolute bottom-0 left-1/2 w-[82%] max-w-none -translate-x-[42%] translate-y-[18%] rotate-[-9deg] transition-transform duration-300 group-hover:translate-y-[14%] group-hover:rotate-[-7deg]"
                                    />
                                </a>
                            )
                        }

                        <a href="/snaps" class="row-span-1 no-underline">
                            <SnapsWidget />
                        </a>

                        <article
                            class="group relative row-span-2 overflow-hidden rounded-[1.6rem] bg-[#eb67bb] p-7 shadow-[inset_0_0_0_1px_rgba(167,53,126,0.08),0_14px_30px_rgba(42,35,29,0.08)]"
                        >
                            <div class="max-w-[11ch]">
                                <h2
                                    class="font-serif text-[2.15rem] leading-[0.98] font-semibold tracking-[-0.04em] text-charcoal lg:text-[2.75rem]"
                                >
                                    Labelling - AI assisted question generation
                                </h2>
                            </div>

                            <img
                                src="/cs-card-1.png"
                                alt=""
                                class="absolute bottom-1 right-[-2.5rem] w-[62%] rotate-[-6deg] opacity-90"
                            />
                        </article>

                        <div class="row-span-1">
                            <MusicWidget songData={songData} client:visible />
                        </div>
                    </div>
                </section>

                <section id="notes" class="flex flex-col gap-5">
                    <p
                        class="font-sans text-sm font-medium tracking-[-0.02em] text-slate"
                    >
                        Notes
                    </p>

                    <div class="flex flex-col gap-4">
                        {
                            heroNotes.map((note) => (
                                <a
                                    href={`/notes/${note.id}`}
                                    class="group no-underline"
                                >
                                    <h3 class="font-sans text-lg leading-[1.15] font-medium tracking-[-0.03em] text-charcoal transition-colors group-hover:text-slate">
                                        {note.data.title}
                                    </h3>
                                </a>
                            ))
                        }
                    </div>
                </section>
            </div>
        </div>
    </SiteShell>
</Base>
