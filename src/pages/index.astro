---
import { getCollection } from "astro:content";
import HeroSection from "@/components/HeroSection";
import WidgetStrip from "@/components/WidgetStrip";
import Base from "@/layouts/Base.astro";
import { getSongData, getWidgetConfig } from "@/lib/widgetConfig";

const notes = (await getCollection("notes", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const songData = await getSongData();
const widgetConfig = getWidgetConfig();
const photoFrame = widgetConfig.photoframe;
---

<Base title="Shreyas Gupta">
    <main
        transition:name="page-main"
        transition:animate="fade"
        class="bg-bg-home min-h-screen flex justify-center px-6"
    >
        <div
            class="w-full max-w-[727px] flex flex-col items-center gap-8 pt-[75px] pb-20"
        >
            <!-- Hero -->
            <HeroSection client:visible />

            <!-- Widget Strip (React island with Lenis horizontal scroll) -->
            <section
                class="w-screen shrink-0"
                transition:persist="widget-strip"
            >
                <WidgetStrip
                    songData={songData}
                    photoFrame={photoFrame}
                    client:visible
                />
            </section>

            <!-- Notes -->
            <section class="w-full flex flex-col items-start gap-9">
                <h2
                    class="font-kyoto font-extrabold text-[clamp(32px,5vw,48px)] leading-[1.2] text-text-primary m-0"
                >
                    Notes
                </h2>
                <div class="flex flex-col gap-6">
                    {
                        notes.map((note) => (
                            <a href={`/notes/${note.id}`} class="no-underline">
                                <article class="flex flex-col gap-3 cursor-pointer">
                                    <h3
                                        transition:name={`note-title-${note.id}`}
                                        class="font-inter font-semibold text-2xl leading-[1.2] tracking-[-0.02em] text-text-primary m-0"
                                    >
                                        {note.data.title}
                                    </h3>
                                </article>
                            </a>
                        ))
                    }
                </div>
            </section>
        </div>
    </main>
</Base>
