---
import { getCollection } from "astro:content";
import Base from "@/layouts/Base.astro";
import SiteShell from "@/components/SiteShell.astro";
import HeroSection from "@/components/HeroSection";
import PhotoFrameWidget from "@/components/widgets/PhotoFrameWidget";
import { getWidgetConfig } from "@/lib/widgetConfig";

const notes = (await getCollection("notes", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const caseStudies = (
    await getCollection("caseStudies", ({ data }) => !data.draft)
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const widgetConfig = getWidgetConfig();
const photoFrame = widgetConfig.photoframe;

const jsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "WebSite",
            "@id": "https://shrey.fyi/#website",
            url: "https://shrey.fyi",
            name: "Shreyas Gupta",
            description:
                "Designer, mushroom grower, and cat dad. Writing about design, technology, and everyday systems.",
            publisher: { "@id": "https://shrey.fyi/#person" },
        },
        {
            "@type": "Person",
            "@id": "https://shrey.fyi/#person",
            name: "Shreyas Gupta",
            url: "https://shrey.fyi",
            jobTitle: "Designer",
            sameAs: [
                "https://github.com/GLaDO8",
                "https://x.com/wutamelonshrey",
            ],
        },
    ],
};
---

<Base
    title="Shreyas Gupta — Designer"
    description="Designer, mushroom grower, and cat dad. Writing about design, technology, and everyday systems."
    bodyClass="bg-parchment"
    seo={{ jsonLd }}
>
    <SiteShell
        currentPath="/"
        containerClass="gap-18"
        mainClass="px-5 pt-32 pb-10"
    >
        <aside
            slot="sidebar"
            data-lenis-prevent
            class="hidden lg:flex flex-col lg:w-[29rem] shrink-0 bg-mist border-x border-fog sticky top-0 h-dvh overflow-y-auto overscroll-y-contain scrollbar-hide"
        >
            <div class="flex items-center justify-end h-8 px-5 shrink-0 mt-16">
                <div
                    class="font-mono text-xs tracking-tight text-charcoal font-medium"
                >
                    v2.1
                </div>
            </div>

            <div class="flex flex-col gap-8 px-5 pt-16 pb-6">
                <PhotoFrameWidget
                    src={photoFrame.src}
                    alt={photoFrame.alt}
                    client:visible
                />

                <HeroSection client:visible />

                <div
                    class="font-sans font-medium text-lg leading-[1.4] text-charcoal"
                >
                    <p class="text-pretty">
                        I build tools at <a
                            href="https://wayground.com/"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="underline decoration-2 underline-offset-3 hover:opacity-80 transition-colors"
                            >Wayground</a
                        > that stand between teachers and everything else that isn't
                        teaching.
                    </p>
                    <p class="mt-4 text-pretty">
                        I used to work on conversational intelligence for sales
                        teams at <a
                            href="https://www.clari.com/products/copilot/"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="underline decoration-2 underline-offset-3 hover:opacity-80 transition-colors"
                            >Clari</a
                        > and built a context-rich SQL editor at
                        <a
                            href="https://atlan.com/"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="underline decoration-2 underline-offset-3 hover:opacity-80 transition-colors"
                            >Atlan</a
                        >.
                    </p>
                </div>
            </div>
        </aside>

        <!-- Mobile-only: photo + hero (visible below lg) -->
        <div class="lg:hidden flex flex-col gap-6 mb-12">
            <PhotoFrameWidget
                src={photoFrame.src}
                alt={photoFrame.alt}
                client:visible
            />

            <HeroSection client:visible />

            <div
                class="font-sans font-medium text-xl leading-[1.4] text-charcoal"
            >
                <p>
                    I build tools at <a
                        href="https://wayground.com/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="underline decoration-1 underline-offset-2 hover:text-slate transition-colors"
                        >Wayground</a
                    > that stand between teachers and everything else that isn't teaching.
                </p>
                <p class="mt-4">
                    I used to work on conversational intelligence for sales
                    teams at <a
                        href="https://www.clari.com/products/copilot/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="underline decoration-1 underline-offset-2 hover:text-slate transition-colors"
                        >Clari</a
                    > and built a context-rich SQL editor at
                    <a
                        href="https://atlan.com/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="underline decoration-1 underline-offset-2 hover:text-slate transition-colors"
                        >Atlan</a
                    >.
                </p>
            </div>
        </div>

        <!-- Work -->
        <section class="flex flex-col gap-6 mb-16">
            <h2
                class="font-serif font-bold text-2xl leading-tight text-charcoal"
            >
                Work
            </h2>
            <div class="flex flex-col gap-6">
                {
                    caseStudies.map((study) => (
                        <a
                            href={`/case-studies/${study.id}`}
                            class="group block no-underline"
                        >
                            <img class="" src="/cs-card-1.png" alt="" />
                        </a>
                    ))
                }
            </div>
        </section>

        <!-- Notes -->
        <section class="flex flex-col gap-6">
            <h2
                class="font-serif font-bold text-2xl leading-tight text-charcoal"
            >
                Notes
            </h2>
            <div class="flex flex-col gap-4">
                {
                    notes.map((note) => (
                        <a
                            href={`/notes/${note.id}`}
                            class="no-underline group"
                        >
                            <h3 class="font-sans font-medium text-lg leading-snug tracking-tight text-charcoal group-hover:text-slate transition-colors">
                                {note.data.title}
                            </h3>
                        </a>
                    ))
                }
            </div>
        </section>
    </SiteShell>
</Base>
