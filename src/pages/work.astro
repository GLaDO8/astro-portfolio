---
import { getCollection } from "astro:content";
import Page from "@/layouts/Page.astro";

const studies = (await getCollection("caseStudies", ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	name: "Work",
	description: "Selected work and case studies by Shreyas Gupta.",
	url: "https://shrey.fyi/work",
};
---

<Page
    title="Work — Shreyas Gupta"
    description="Selected work and case studies by Shreyas Gupta."
    bodyClass="bg-parchment"
    class="bg-parchment"
    seo={{ jsonLd }}
>
    <section class="col-span-full md:col-span-8 md:col-start-3 lg:col-span-10 lg:col-start-3">
        <header class="mt-8 mb-10">
            <h1
                class="font-serif font-bold text-4xl leading-[1.1] tracking-[-0.03em] text-charcoal text-balance"
            >
                Work
            </h1>
            <p class="mt-3 max-w-2xl font-sans text-base leading-relaxed text-slate">
                Selected case studies and shipped product work.
            </p>
        </header>

        <div class="flex flex-col gap-6">
            {
                studies.map((study) => (
                    <a
                        href={`/case-studies/${study.id}`}
                        class="rounded-[1.5rem] border border-black/6 bg-white/70 p-6 no-underline transition-transform duration-200 hover:-translate-y-0.5"
                    >
                        <p class="font-sans text-sm text-slate">
                            {
                                study.data.date.toLocaleDateString("en-US", {
                                    year: "numeric",
                                    month: "long",
                                })
                            }
                        </p>
                        <h2 class="mt-2 font-serif text-2xl leading-[1.05] font-semibold tracking-[-0.04em] text-charcoal">
                            {study.data.title}
                        </h2>
                        <p class="mt-3 max-w-[62ch] font-sans text-base leading-relaxed text-slate text-pretty">
                            {study.data.description}
                        </p>
                    </a>
                ))
            }
        </div>
    </section>
</Page>
