---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import ArticleProse from "@/components/mdoc/ArticleProse.astro";
import Page from "@/layouts/Page.astro";
import { getImageAsset } from "@/lib/imageAssets";

const themeStyles: Record<string, string> = {
    "hot-text":
        "prose-h2:text-base md:prose-h2:text-base prose-h2:text-[#DA0288] prose-h2:uppercase",
};

export async function getStaticPaths() {
    const studies = await getCollection("caseStudies");
    return studies.map((study) => ({
        params: { slug: study.id },
        props: { study },
    }));
}

const { study } = Astro.props;
const { Content } = await render(study);
const theme = study.data.theme;
const heroImageSrc = study.data.heroImage;
const heroImage = getImageAsset(heroImageSrc);
const heroImageAlt = study.data.heroImageAlt ?? study.data.title;
const publishedDate = study.data.date.toISOString();
const publishedDay = publishedDate.slice(0, 10);
const readableDate = study.data.date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
});

const jsonLd = {
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    name: study.data.title,
    description: study.data.description,
    datePublished: publishedDate,
    author: {
        "@type": "Person",
        "@id": "https://shrey.fyi/#person",
        name: "Shreyas Gupta",
    },
    url: `https://shrey.fyi/work/${study.id}`,
};
---

<Page
    title={`${study.data.title} — Shreyas Gupta`}
    description={study.data.description}
    bodyClass="bg-white"
    class="bg-white"
    navBlurBackground="white"
    seo={{
        ogType: "article",
        article: {
            publishedTime: publishedDate,
        },
        jsonLd,
    }}
>
    {
        heroImageSrc && (
            <figure class="col-span-full mb-4 md:col-span-10 md:col-start-2 lg:col-span-12 lg:col-start-3">
                {heroImage ? (
                    <Image
                        src={heroImage}
                        alt={heroImageAlt}
                        loading="eager"
                        fetchpriority="high"
                        class="h-auto w-full rounded-xl"
                    />
                ) : (
                    <img
                        src={heroImageSrc}
                        alt={heroImageAlt}
                        loading="eager"
                        fetchpriority="high"
                        class="h-auto w-full rounded-xl"
                    />
                )}
            </figure>
        )
    }
    <time
        datetime={publishedDay}
        class="font-sans col-span-full md:col-span-10 md:col-start-2 lg:col-span-12 lg:col-start-3 text-center text-secondary"
    >
        {readableDate}
    </time>
    <h1
        class:list={[
            "col-span-full md:col-span-10 md:col-start-2 lg:col-span-12 lg:col-start-3 font-sans font-bold text-4xl leading-[1.15] tracking-[-0.02em] text-primary text-center text-balance md:text-5xl md:leading-[1.1] lg:text-6xl",
            heroImageSrc ? "mb-8 md:mb-10" : "mb-16",
        ]}
    >
        {study.data.title}
    </h1>

    <article
        class="col-span-full md:col-span-8 md:col-start-3 lg:col-span-8 lg:col-start-5"
    >
        <ArticleProse class={theme && themeStyles[theme]}>
            <Content />
        </ArticleProse>
    </article>
</Page>
