---
import { getCollection, render } from "astro:content";
import Page from "@/layouts/Page.astro";

export async function getStaticPaths() {
    const studies = await getCollection(
        "caseStudies",
        ({ data }) => !data.draft,
    );
    return studies.map((study) => ({
        params: { slug: study.id },
        props: { study },
    }));
}

const { study } = Astro.props;
const { Content } = await render(study);
---

<Page title={study.data.title} bodyClass="bg-bg-home" class="bg-bg-home">
    <article
        class="col-span-full md:col-span-8 md:col-start-3 lg:col-span-8 lg:col-start-3"
    >
        <h1
            class="font-serif font-bold text-4xl leading-[1.2] tracking-[-0.02em] text-text-primary mb-1 text-balance"
        >
            {study.data.title}
        </h1>
        <div
            class="prose prose-headings:font-serif prose-headings:font-bold prose-headings:tracking-normal font-sans text-base leading-relaxed text-text-primary text-pretty overflow-visible"
        >
            <Content />
        </div>
    </article>
</Page>
