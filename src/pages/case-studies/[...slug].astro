---
import { getCollection, render } from "astro:content";
import Page from "@/layouts/Page.astro";
import { cn } from "@/lib/cn";

const baseProseClass =
	"prose prose-headings:font-serif prose-headings:font-bold prose-headings:tracking-normal prose-li:marker:text-charcoal prose-code:before:content-none prose-code:after:content-none prose-code:bg-[#b0d8d8] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:font-normal leading-relaxed text-charcoal text-pretty overflow-visible prose-img:rounded-lg prose-h1:text-4xl prose-h2:text-3xl prose-h3:text-2xl";

const themeStyles: Record<string, string> = {
	"hot-text":
		"prose-h2:text-base prose-h2:text-[#DA0288] font-sans text-base font-medium prose-h2:uppercase",
};

export async function getStaticPaths() {
	const studies = await getCollection("caseStudies", ({ data }) => !data.draft);
	return studies.map((study) => ({
		params: { slug: study.id },
		props: { study },
	}));
}

const { study } = Astro.props;
const { Content } = await render(study);
const theme = study.data.theme;
const proseClass = cn(baseProseClass, theme && themeStyles[theme]);

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "CreativeWork",
	name: study.data.title,
	description: study.data.description,
	datePublished: study.data.date.toISOString(),
	author: {
		"@type": "Person",
		"@id": "https://shrey.fyi/#person",
		name: "Shreyas Gupta",
	},
	url: `https://shrey.fyi/case-studies/${study.id}`,
};
---

<Page
    title={`${study.data.title} — Shreyas Gupta`}
    description={study.data.description}
    bodyClass="bg-white"
    class="bg-white"
    seo={{
        ogType: "article",
        article: {
            publishedTime: study.data.date.toISOString(),
        },
        jsonLd,
    }}
>
    <h1
        class="col-span-full md:col-span-8 md:col-start-3 lg:col-span-12 lg:col-start-3 font-serif font-bold text-4xl leading-[1.2] tracking-[-0.02em] text-charcoal my-16 text-balance"
    >
        {study.data.title}
    </h1>
    <article
        class="col-span-full md:col-span-8 md:col-start-3 lg:col-span-8 lg:col-start-3"
    >
        <div class={proseClass}>
            <Content />
        </div>
    </article>
</Page>
