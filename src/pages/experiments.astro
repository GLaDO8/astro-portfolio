---
import Page from "@/layouts/Page.astro";

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	name: "Experiments",
	description: "Experiments by Shreyas Gupta.",
	url: "https://shrey.fyi/experiments",
};
---

<Page
    title="Experiments — Shreyas Gupta"
    description="Experiments by Shreyas Gupta."
    bodyClass="bg-beige"
    class="bg-beige"
    seo={{ jsonLd }}
>
    <section class="col-span-full md:col-span-8 md:col-start-3 lg:col-span-8 lg:col-start-5">
        <h1
            class="mt-8 font-sans text-4xl leading-[1.1] font-bold tracking-[-0.03em] text-primary md:text-5xl"
        >
            Experiments
        </h1>
        <p class="mt-4 max-w-2xl font-sans text-base leading-relaxed text-secondary md:text-lg">
            This page is a temporary stub for side projects, prototypes, and playful
            builds.
        </p>
    </section>
</Page>
