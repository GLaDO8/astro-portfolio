---
import Base from "@/layouts/Base.astro";
---

<Base title="About — Shreyas" bodyClass="bg-bg-home">
  <main class="bg-bg-home min-h-screen flex justify-center px-6">
    <article class="w-full max-w-[727px] pt-[75px] pb-20">
      <a href="/" class="font-inter text-sm text-text-secondary hover:text-text-primary transition-colors">&larr; Back</a>

      <h1 class="font-kyoto font-[800] text-[clamp(32px,5vw,48px)] leading-[1.2] text-text-hero mt-8 mb-6">
        About
      </h1>

      <div class="font-garamond text-lg leading-relaxed text-text-primary flex flex-col gap-6">
        <p class="m-0">
          Hi, I'm Shreyas. Designer, mushroom grower, and cat dad.
        </p>
        <p class="m-0">
          More coming soon.
        </p>
      </div>
    </article>
  </main>
</Base>
