---
import Page from "@/layouts/Page.astro";
---

<Page title="About — Shreyas" bodyClass="bg-bg-home" class="bg-bg-home">
    <article class="col-span-full md:col-span-8 md:col-start-3 lg:col-span-8 lg:col-start-5">
        <h1
            class="font-serif font-bold text-[clamp(32px,5vw,48px)] leading-[1.2] text-text-hero mt-8 mb-6"
        >
            About
        </h1>

        <div
            class="font-sans text-base leading-relaxed text-text-primary flex flex-col gap-6"
        >
            <p class="m-0">
                Hi, I'm Shreyas. Designer, mushroom grower, and cat dad.
            </p>
            <p class="m-0">More coming soon.</p>
        </div>
    </article>
</Page>
