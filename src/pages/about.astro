---
import Page from "@/layouts/Page.astro";

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "ProfilePage",
	mainEntity: {
		"@type": "Person",
		"@id": "https://shrey.fyi/#person",
		name: "Shreyas Gupta",
		url: "https://shrey.fyi",
		jobTitle: "Designer",
		description: "Designer, mushroom grower, and cat dad.",
		sameAs: ["https://github.com/GLaDO8", "https://x.com/wutamelonshrey"],
	},
};
---

<Page
	title="About — Shreyas Gupta"
	description="About Shreyas Gupta — designer, mushroom grower, and cat dad. Learn more about what I do and how I think."
	bodyClass="bg-parchment"
	class="bg-parchment"
	seo={{ jsonLd }}
>
	<article class="col-span-full md:col-span-8 md:col-start-3 lg:col-span-8 lg:col-start-5">
		<h1
			class="font-sans font-bold text-3xl leading-[1.2] text-charcoal mt-8 mb-6 text-balance"
		>
			About
		</h1>

		<div
			class="font-sans text-base leading-relaxed text-charcoal flex flex-col gap-6"
		>
			<p class="m-0">
				Hi, I'm Shreyas. Designer, mushroom grower, and cat dad.
			</p>
			<p class="m-0">More coming soon.</p>
		</div>
	</article>
</Page>
