---
import { getCollection, render } from "astro:content";
import Page from "@/layouts/Page.astro";

export async function getStaticPaths() {
	const notes = await getCollection("notes", ({ data }) => !data.draft);
	return notes.map((note) => ({
		params: { slug: note.id },
		props: { note },
	}));
}

const { note } = Astro.props;
const { Content } = await render(note);

const description = note.data.description || note.data.subtitle || note.data.title;

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "Article",
	headline: note.data.title,
	description,
	datePublished: note.data.date.toISOString(),
	author: {
		"@type": "Person",
		"@id": "https://shrey.fyi/#person",
		name: "Shreyas Gupta",
	},
	publisher: {
		"@type": "Person",
		"@id": "https://shrey.fyi/#person",
		name: "Shreyas Gupta",
	},
	url: `https://shrey.fyi/notes/${note.id}`,
};
---

<Page
	title={`${note.data.title} — Shreyas Gupta`}
	description={description}
	bodyClass="bg-parchment"
	class="bg-parchment"
	seo={{
		ogType: "article",
		article: {
			publishedTime: note.data.date.toISOString(),
			tags: note.data.tags,
		},
		jsonLd,
	}}
>
	<article
		class="col-span-full md:col-span-8 md:col-start-3 lg:col-span-8 lg:col-start-3"
	>
		<h1
			class="font-serif font-bold text-4xl leading-[1.2] tracking-[-0.02em] text-charcoal mt-8 mb-2 text-balance"
		>
			{note.data.title}
		</h1>
		<p class="font-sans text-slate mb-12">
			{
				note.data.date.toLocaleDateString("en-US", {
					year: "numeric",
					month: "long",
					day: "numeric",
				})
			}
		</p>
		<div
			class="prose prose-headings:font-serif prose-headings:font-bold prose-headings:tracking-normal font-sans text-base leading-relaxed text-charcoal text-pretty overflow-visible"
		>
			<Content />
		</div>
	</article>
</Page>
