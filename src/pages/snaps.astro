const firstRowItemCount = (() => {
    let columnSpan = 0;

    for (const [index, item] of snaps.entries()) {
        columnSpan += item.span;

        if (columnSpan >= 12) {
            return index + 1;
        }
    }

    return snaps.length;
})();
---

<SnapsLayout
    title="Snaps — Shreyas Gupta"
    description="A collection of photographs by Shreyas Gupta."
    bodyClass="bg-parchment"
    navBlurBackground="bg-parchment"
>
    <!-- Title -->
    <div class="flex flex-col items-center gap-0 mb-16 mt-8">
        <h1
            class="font-sans font-bold text-6xl leading-none text-charcoal pb-4 md:text-7xl lg:text-8xl uppercase tracking-tight"
        >
            Photo Roll
        </h1>
        <p class="font-sans font-medium text-lg text-slate md:text-xl">
            Poetry written with my cameras.
        </p>
    </div>

    <!-- Photo grid -->
    <SnapsGallery snaps={snaps} priorityCount={firstRowItemCount} client:visible />
</SnapsLayout>
