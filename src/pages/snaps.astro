---
/// <reference types="node" />
import { promises as fs } from "node:fs";
import path from "node:path";
import Page from "@/layouts/Page.astro";

const snapsDir = path.join(process.cwd(), "public", "snaps");
let photos: string[] = [];
try {
	const files = await fs.readdir(snapsDir);
	photos = files.filter((f) => /\.(jpe?g|png|webp|avif|gif)$/i.test(f)).sort();
} catch {}
---

<Page
	title="Snaps — Shreyas Gupta"
	description="A collection of photographs by Shreyas Gupta."
	bodyClass="bg-bg-home"
	class="bg-bg-home"
>
    <div
        class="col-span-full md:col-span-10 md:col-start-2 lg:col-span-12 lg:col-start-3 flex flex-col items-start gap-9"
    >
        <h1
            class="font-serif font-bold text-3xl leading-[1.2] text-text-hero m-0 text-balance"
        >
            Snaps
        </h1>

        {
            photos.length > 0 ? (
                <div class="w-full columns-2 gap-4 sm:columns-3">
                    {photos.map((photo) => (
                        <img
                            src={`/snaps/${photo}`}
                            alt={photo.replace(/\.[^.]+$/, "")}
                            class="w-full mb-4 rounded-lg"
                            loading="lazy"
                        />
                    ))}
                </div>
            ) : (
                <p class="font-sans text-[16px] text-text-secondary">
                    No snaps yet. Drop photos into{" "}
                    <code class="bg-black/5 px-1.5 py-0.5 rounded text-[14px]">
                        public/snaps/
                    </code>{" "}
                    to see them here.
                </p>
            )
        }
    </div>
</Page>
