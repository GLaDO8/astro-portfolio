import type { ImageMetadata } from "astro";
import SnapsGallery from "@/components/snaps/SnapsGallery";
import SnapsLayout from "@/layouts/SnapsLayout.astro";
import { getRequiredImageAsset } from "@/lib/imageAssets";

type SnapItemInput = {
    src: string;
    date: string;
    year: number;
    caption: string;
    span: number;
};

type SnapItem = SnapItemInput & {
    image: ImageMetadata;
};

const withDimensions = (item: SnapItemInput): SnapItem => ({
    ...item,
    image: getRequiredImageAsset(item.src),
});

