const initialRowCount = 3;
const initialRows = rows.slice(0, initialRowCount);
const deferredRows = rows.slice(initialRowCount);
---

<Base
    title="Snaps — Shreyas Gupta"
    description="A collection of photographs by Shreyas Gupta."
    bodyClass="bg-parchment"
>
    <SiteShell currentPath="/snaps" mainClass="px-5 pb-20">
        <!-- Title -->
        <div class="flex flex-col items-center gap-0 mb-16">
            <h1
                class="font-serif font-bold text-7xl leading-none text-charcoal pb-4"
            >
                Snaps
            </h1>
            <p class="font-sans text-xl text-slate">
                Poetry written with my cameras.
            </p>
        </div>

        <!-- Photo grid -->
        <div class="flex flex-col gap-16" data-snaps-grid>
            {
                initialRows.map((row, rowIndex) => (
                    <div class="grid grid-cols-12 gap-4">
                        {row.map((item) => (
                            <div style={`grid-column: span ${item.span};`}>
                                {/* <p class="font-sans text-sm font-semibold text-slate mb-2 uppercase">
                                    {item.date}
                                </p> */}
                                <img
                                    src={item.src}
                                    alt={item.caption}
                                    class="w-full object-cover"
                                    width={item.width}
                                    height={item.height}
                                    loading={rowIndex === 0 ? "eager" : "lazy"}
                                    fetchpriority={rowIndex === 0 ? "high" : "auto"}
                                    decoding="async"
                                />
                                {item.caption && (
                                    <p class="font-sans text-sm font-medium text-slate mt-2">
                                        {item.caption}
                                    </p>
                                )}
                            </div>
                        ))}
                    </div>
                ))
            }

            {
                deferredRows.length > 0 && (
                    <>
                        <div class="h-px w-full" data-snaps-sentinel aria-hidden="true"></div>

                        <noscript>
                            {
                                deferredRows.map((row) => (
                                    <div class="grid grid-cols-12 gap-4">
                                        {row.map((item) => (
                                            <div style={`grid-column: span ${item.span};`}>
                                                <img
                                                    src={item.src}
                                                    alt={item.caption}
                                                    class="w-full object-cover"
                                                    width={item.width}
                                                    height={item.height}
                                                    loading="lazy"
                                                    fetchpriority="low"
                                                    decoding="async"
                                                />
                                                {item.caption && (
                                                    <p class="font-sans text-sm font-medium text-slate mt-2">
                                                        {item.caption}
                                                    </p>
                                                )}
                                            </div>
                                        ))}
                                    </div>
                                ))
                            }
                        </noscript>

                        <script is:inline define:vars={{ deferredRows }}>
                            const snapsGrid = document.querySelector("[data-snaps-grid]");
                            const snapsSentinel = document.querySelector("[data-snaps-sentinel]");
                            const pendingRows = Array.isArray(deferredRows) ? [...deferredRows] : [];
                            const batchSize = 2;

                            const renderDeferredRow = (row) => {
                                const rowElement = document.createElement("div");
                                rowElement.className = "grid grid-cols-12 gap-4";

                                row.forEach((item) => {
                                    const cell = document.createElement("div");
                                    cell.style.gridColumn = `span ${item.span}`;

                                    const image = document.createElement("img");
                                    image.src = item.src;
                                    image.alt = item.caption;
                                    image.className = "w-full object-cover";
                                    image.width = item.width;
                                    image.height = item.height;
                                    image.loading = "lazy";
                                    image.fetchPriority = "low";
                                    image.decoding = "async";
                                    cell.append(image);

                                    if (item.caption) {
                                        const caption = document.createElement("p");
                                        caption.className = "font-sans text-sm font-medium text-slate mt-2";
                                        caption.textContent = item.caption;
                                        cell.append(caption);
                                    }

                                    rowElement.append(cell);
                                });

                                return rowElement;
                            };

                            const appendNextBatch = () => {
                                if (!snapsGrid || !snapsSentinel || pendingRows.length === 0) {
                                    snapsSentinel?.remove();
                                    return;
                                }

                                for (
                                    let index = 0;
                                    index < batchSize && pendingRows.length > 0;
                                    index += 1
                                ) {
                                    const nextRow = pendingRows.shift();

                                    if (nextRow) {
                                        snapsGrid.insertBefore(
                                            renderDeferredRow(nextRow),
                                            snapsSentinel,
                                        );
                                    }
                                }

                                if (pendingRows.length === 0) {
                                    snapsSentinel.remove();
                                }
                            };

                            if (snapsGrid && snapsSentinel && pendingRows.length > 0) {
                                const observer = new IntersectionObserver(
                                    (entries) => {
                                        if (entries.some((entry) => entry.isIntersecting)) {
                                            appendNextBatch();

                                            if (pendingRows.length === 0) {
                                                observer.disconnect();
                                            }
                                        }
                                    },
                                    { rootMargin: "900px 0px" },
                                );

                                observer.observe(snapsSentinel);
                            }
                        </script>
                    </>
                )
            }
        </div>
    </SiteShell>
</Base>
