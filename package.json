{
	"name": "shreyas-site",
	"type": "module",
	"version": "1.3.0",
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "astro dev",
		"build": "pnpm images && astro build",
		"build:astro": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"test": "node --test tests/**/*.test.mjs",
		"verify:changed": "node scripts/verify-changed.mjs",
		"verify:content": "node scripts/verify-content.mjs",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"check": "biome check .",
		"check:design": "node scripts/check-design-tokens.mjs",
		"images": "node scripts/optimize-images.mjs",
		"images:watch": "node scripts/optimize-images.mjs --watch"
	},
	"dependencies": {
		"@astrojs/markdoc": "^1.0.4",
		"@astrojs/react": "^5.0.4",
		"@astrojs/sitemap": "^3.7.2",
		"@google/model-viewer": "^4.2.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"agentation": "^2.3.0",
		"astro": "^6.2.1",
		"clsx": "^2.1.1",
		"lenis": "^1.3.18",
		"mesurer": "^0.0.3",
		"motion": "^12.38.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"smol-toml": "^1.6.0",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@markdoc/markdoc": "0.5.7",
		"@types/node": "^25.3.5",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"sharp": "^0.34.5",
		"typescript": "^5.7.0",
		"vite": "7.3.2"
	}
}
